---
import Layout from '../layouts/Layout.astro';
import LeftSidebar from '../components/LeftSidebar.astro';
import RightSidebar from '../components/RightSidebar.astro';
import EditorCanvas from '../components/EditorCanvas.astro';
import { defaultFont } from '../config/fonts';

const initialCSS = `${defaultFont.fontFace}
.preview-text {
  font-family: ${defaultFont.fontFamily};
  font-size: 16px;
  line-height: 1.5;
  letter-spacing: 0em;
  text-align: left;
  color: #000000;
  font-variation-settings: 'wght' ${defaultFont.axes.find(a => a.tag === 'wght')?.default || 400}, 'wdth' ${defaultFont.axes.find(a => a.tag === 'wdth')?.default || 100}, 'opsz' ${defaultFont.axes.find(a => a.tag === 'opsz')?.default || 14};
}`;
---

<Layout>
  <div class="flex flex-col lg:flex-row h-screen overflow-hidden">
    <!-- Left Sidebar -->
    <LeftSidebar />

    <!-- Main Canvas -->
    <main id="main-area" class="flex-1 overflow-y-auto bg-white relative shadow-inner order-3 lg:order-2">
      <EditorCanvas />
    </main>

    <!-- Right Sidebar -->
    <RightSidebar initialCSS={initialCSS} />
  </div>

  <style is:global>
    .preview-text {
      font-family: var(--font-family, 'Google Sans', sans-serif);
      outline: none;
    }
  </style>

  <script>
    import { defaultFont, fonts } from '../config/fonts';

    const root = document.documentElement;

    // Initial Font Family
    let currentFontFamily = defaultFont.fontFamily;

    const activeFontId = localStorage.getItem('activeFontId');
    if (activeFontId) {
        const foundFont = fonts.find(f => f.id === activeFontId);
        if (foundFont) {
            currentFontFamily = foundFont.fontFamily;
        }
    }

    root.style.setProperty('--font-family', currentFontFamily);

    window.addEventListener('font-selected', (e) => {
      const event = e as CustomEvent;
      currentFontFamily = event.detail.fontFamily;
      root.style.setProperty('--font-family', currentFontFamily);
    });
  </script>
</Layout>
