---
import '../styles/global.css';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Typography Playground</title>
  </head>
  <body class="min-h-screen p-8 flex flex-col md:flex-row gap-8">
    <aside class="w-full md:w-80 shrink-0 bg-white p-6 rounded-lg shadow-sm border border-slate-200 h-fit">
      <h1 class="text-2xl font-bold mb-6 text-slate-800">Typography Playground</h1>

      <div class="space-y-6">
        <div>
          <label for="font-family" class="block text-sm font-medium text-slate-700 mb-1">Font Family</label>
          <select id="font-family" class="w-full border border-slate-300 rounded-md shadow-sm p-2 focus:ring-blue-500 focus:border-blue-500">
            <option value="'Google Sans', sans-serif">Google Sans</option>
            <option value="'Google Sans Mono', monospace">Google Sans Mono</option>
            <option value="'Google Sans Code', monospace">Google Sans Code</option>
          </select>
        </div>

        <div>
          <label for="font-size" class="flex justify-between text-sm font-medium text-slate-700 mb-1">
            <span>Font Size</span>
            <span id="font-size-val">16px</span>
          </label>
          <input type="range" id="font-size" min="12" max="72" value="16" class="w-full">
        </div>

        <div>
          <label for="font-weight" class="flex justify-between text-sm font-medium text-slate-700 mb-1">
            <span>Font Weight</span>
            <span id="font-weight-val">400</span>
          </label>
          <input type="range" id="font-weight" min="100" max="900" step="100" value="400" class="w-full">
        </div>

        <div>
          <label for="line-height" class="flex justify-between text-sm font-medium text-slate-700 mb-1">
            <span>Line Height</span>
            <span id="line-height-val">1.5</span>
          </label>
          <input type="range" id="line-height" min="1" max="2.5" step="0.1" value="1.5" class="w-full">
        </div>

        <div>
          <label for="letter-spacing" class="flex justify-between text-sm font-medium text-slate-700 mb-1">
            <span>Letter Spacing</span>
            <span id="letter-spacing-val">0em</span>
          </label>
          <input type="range" id="letter-spacing" min="-0.1" max="0.5" step="0.01" value="0" class="w-full">
        </div>
      </div>
    </aside>

    <main class="flex-1 bg-white p-8 rounded-lg shadow-sm border border-slate-200 overflow-hidden flex flex-col gap-12" id="preview-area">
      <section>
        <h2 class="text-sm font-semibold text-slate-500 uppercase tracking-wider mb-4">Paragraph Preview</h2>
        <div class="preview-text" contenteditable="true">
          <p>
            Typography is the art and technique of arranging type to make written language legible, readable, and appealing when displayed. The arrangement of type involves selecting typefaces, point sizes, line lengths, line-spacing (leading), and letter-spacing (tracking), and adjusting the space between pairs of letters (kerning).
          </p>
          <p class="mt-4">
            The term typography is also applied to the style, arrangement, and appearance of the letters, numbers, and symbols created by the process. Type design is a closely related craft, sometimes considered part of typography. Feel free to edit this text to see how the font looks with your own content!
          </p>
        </div>
      </section>

      <section>
        <h2 class="text-sm font-semibold text-slate-500 uppercase tracking-wider mb-4">Code Preview</h2>
        <pre class="preview-text bg-slate-900 text-slate-50 p-6 rounded-lg overflow-x-auto" contenteditable="true"><code>{`function calculateFibonacci(n) {
  if (n <= 1) return n;

  let prev = 0;
  let curr = 1;

  for (let i = 2; i <= n; i++) {
    const next = prev + curr;
    prev = curr;
    curr = next;
  }

  return curr;
}

// Example usage:
const result = calculateFibonacci(10);
console.log(\`The 10th Fibonacci number is \${result}\`);`}</code></pre>
      </section>

      <section>
        <h2 class="text-sm font-semibold text-slate-500 uppercase tracking-wider mb-4">Alphabet & Numbers</h2>
        <div class="preview-text break-all">
          ABCDEFGHIJKLMNOPQRSTUVWXYZ<br/>
          abcdefghijklmnopqrstuvwxyz<br/>
          0123456789<br/>
          !@#$%^&*()_+-=[]{}|;':",./&lt;&gt;?
        </div>
      </section>
    </main>

    <style>
      .preview-text {
        font-family: var(--font-family);
        font-size: var(--font-size);
        font-weight: var(--font-weight);
        line-height: var(--line-height);
        letter-spacing: var(--letter-spacing);
        outline: none;
      }
      .preview-text:focus {
        box-shadow: 0 0 0 2px rgba(59, 130, 246, 0.5);
        border-radius: 0.25rem;
      }
    </style>

    <script>
      const root = document.documentElement;

      const controls = {
        fontFamily: document.getElementById('font-family') as HTMLSelectElement,
        fontSize: document.getElementById('font-size') as HTMLInputElement,
        fontWeight: document.getElementById('font-weight') as HTMLInputElement,
        lineHeight: document.getElementById('line-height') as HTMLInputElement,
        letterSpacing: document.getElementById('letter-spacing') as HTMLInputElement,
      };

      const values = {
        fontSize: document.getElementById('font-size-val'),
        fontWeight: document.getElementById('font-weight-val'),
        lineHeight: document.getElementById('line-height-val'),
        letterSpacing: document.getElementById('letter-spacing-val'),
      };

      function updateTypography() {
        // Update CSS variables
        root.style.setProperty('--font-family', controls.fontFamily.value);
        root.style.setProperty('--font-size', `${controls.fontSize.value}px`);
        root.style.setProperty('--font-weight', controls.fontWeight.value);
        root.style.setProperty('--line-height', controls.lineHeight.value);
        root.style.setProperty('--letter-spacing', `${controls.letterSpacing.value}em`);

        // Update display values
        if (values.fontSize) values.fontSize.textContent = `${controls.fontSize.value}px`;
        if (values.fontWeight) values.fontWeight.textContent = controls.fontWeight.value;
        if (values.lineHeight) values.lineHeight.textContent = controls.lineHeight.value;
        if (values.letterSpacing) values.letterSpacing.textContent = `${controls.letterSpacing.value}em`;
      }

      // Add event listeners
      Object.values(controls).forEach(control => {
        if (control) {
          control.addEventListener('input', updateTypography);
        }
      });
    </script>
  </body>
</html>
