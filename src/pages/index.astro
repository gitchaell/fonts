---
import '../styles/global.css';
import { Code } from 'astro:components';

const initialCSS = `
.preview-text {
  font-family: 'Google Sans', sans-serif;
  font-size: 93px;
  font-variation-settings: 'wght' 708.5, 'wdth' 66.88, 'opsz' 39.82;
}`;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Typography Playground</title>
  </head>
  <body class="min-h-screen bg-[#f3f4f6] flex flex-col font-sans overflow-hidden">
    <!-- Top Header -->
    <header id="top-header" class="h-[48px] bg-white border-b border-slate-200 flex items-center justify-center px-6 shrink-0 z-10 relative">
      <h1 class="absolute left-6 text-[17px] font-bold text-[#111] font-sans tracking-tight"><span class="text-[#3a82f6]">Font</span> Playground</h1>

      <div class="flex items-center gap-8 text-[13px] font-medium text-slate-400">
        <button class="text-slate-900 border-b-2 border-slate-900 pb-[13px] pt-[15px] -mb-[2px]">Design</button>
        <button class="hover:text-slate-900 transition-colors pb-[13px] pt-[15px] -mb-[2px]">Code</button>
      </div>
    </header>

    <!-- Main Layout -->
    <div class="flex-1 flex overflow-hidden h-[calc(100vh-48px)]">
      <!-- Left Sidebar -->
      <aside id="left-sidebar" class="w-[260px] bg-white border-r border-slate-200 flex flex-col overflow-hidden shrink-0">
        <div class="flex flex-col h-full bg-[#f8f9fa]">
          <!-- Font Family Header & Search -->
          <div class="px-4 py-4 border-b border-slate-200">
            <h2 class="text-[11px] font-bold text-slate-400 uppercase tracking-wider mb-3">Font Family</h2>
            <div class="relative">
              <input type="text" placeholder="Search by name, axis, designer..." class="w-full text-[13px] bg-transparent border-b border-slate-200 pb-1 outline-none placeholder:text-slate-400 focus:border-blue-500 transition-colors">
              <svg class="w-3.5 h-3.5 text-slate-400 absolute right-0 top-1" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
            </div>
          </div>

          <!-- Font List -->
          <div class="flex-1 overflow-y-auto px-2 py-2 space-y-1" id="font-list">

            <!-- Active Font -->
            <button class="font-item w-full text-left p-2 rounded bg-white border border-blue-400 shadow-sm relative" data-font="'Google Sans', sans-serif" data-name="Google Sans">
              <div class="absolute left-0 top-0 bottom-0 w-1 bg-blue-500 rounded-l font-active-indicator"></div>
              <div class="flex justify-between items-center mb-1 pl-1">
                <span class="text-[12px] font-medium text-slate-900 font-name-display">Google Sans</span>
                <div class="flex items-center text-slate-500 text-[10px]">
                  <svg class="w-3 h-3 mr-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="6" cy="12" r="2"/><circle cx="18" cy="12" r="2"/><path d="M8 12h8"/></svg>
                  1
                </div>
              </div>
              <div class="text-xl text-slate-800 pl-1" style="font-family: 'Google Sans', sans-serif;">Google Sans</div>
            </button>

            <button class="font-item w-full text-left p-2 rounded hover:bg-slate-100 group relative" data-font="'Google Sans Mono', monospace" data-name="Google Sans Mono">
              <div class="absolute left-0 top-0 bottom-0 w-1 bg-blue-500 rounded-l font-active-indicator hidden"></div>
              <div class="flex justify-between items-center mb-1 pl-1">
                <span class="text-[12px] font-medium text-slate-700 group-hover:text-slate-900 font-name-display">Google Sans Mono</span>
                <div class="flex items-center text-slate-400 group-hover:text-slate-500 text-[10px]">
                  <svg class="w-3 h-3 mr-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="6" cy="12" r="2"/><circle cx="18" cy="12" r="2"/><path d="M8 12h8"/></svg>
                  1
                </div>
              </div>
              <div class="text-xl text-slate-800 pl-1" style="font-family: 'Google Sans Mono', monospace;">Google Mono</div>
            </button>

            <button class="font-item w-full text-left p-2 rounded hover:bg-slate-100 group relative" data-font="'Google Sans Code', monospace" data-name="Google Sans Code">
              <div class="absolute left-0 top-0 bottom-0 w-1 bg-blue-500 rounded-l font-active-indicator hidden"></div>
              <div class="flex justify-between items-center mb-1 pl-1">
                <span class="text-[12px] font-medium text-slate-700 group-hover:text-slate-900 font-name-display">Google Sans Code</span>
                <div class="flex items-center text-slate-400 group-hover:text-slate-500 text-[10px]">
                  <svg class="w-3 h-3 mr-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="6" cy="12" r="2"/><circle cx="18" cy="12" r="2"/><path d="M8 12h8"/></svg>
                  1
                </div>
              </div>
              <div class="text-xl text-slate-800 pl-1" style="font-family: 'Google Sans Code', monospace;">Google Code</div>
            </button>

          </div>

          <!-- Font Info -->
          <div class="p-4 border-t border-slate-200 bg-white">
            <h2 class="text-[11px] font-bold text-slate-400 uppercase tracking-wider mb-3">Font Info</h2>

            <div class="border border-blue-400 rounded p-2 mb-4 relative shadow-sm">
               <div class="absolute left-0 top-0 bottom-0 w-1 bg-blue-500 rounded-l"></div>
              <div class="flex justify-between items-center mb-1 pl-1">
                <span class="text-[12px] font-medium text-slate-900" id="info-font-name">Google Sans</span>
                <div class="flex items-center text-slate-500 text-[10px]">
                  <svg class="w-3 h-3 mr-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="6" cy="12" r="2"/><circle cx="18" cy="12" r="2"/><path d="M8 12h8"/></svg>
                  1
                </div>
              </div>
              <div class="text-xl text-slate-800 pl-1" id="info-font-preview" style="font-family: 'Google Sans', sans-serif;">Google Sans</div>
            </div>

            <table class="text-[12px] w-full border-collapse">
              <tbody>
                <tr>
                  <td class="text-slate-500 py-1 align-top w-20">Designer</td>
                  <td class="text-slate-900 py-1">Google</td>
                </tr>
                <tr>
                  <td class="text-slate-500 py-1 align-top">Publisher</td>
                  <td class="text-slate-900 py-1">Google Fonts</td>
                </tr>
                <tr>
                  <td class="text-slate-500 py-1 align-top">License</td>
                  <td class="text-slate-900 py-1">OFL</td>
                </tr>
                <tr>
                  <td class="text-slate-500 py-1 align-top">Link</td>
                  <td class="text-slate-900 py-1"><a href="https://fonts.google.com/" class="hover:underline text-blue-500">fonts.google.com</a></td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </aside>

      <!-- Main Canvas -->
      <main id="main-area" class="flex-1 bg-white relative overflow-auto shadow-inner p-12">
        <div id="design-view" class="max-w-4xl mx-auto flex flex-col gap-8 pb-32">

          <div id="editorjs" class="preview-text"></div>

        </div>

        <div id="code-view" class="hidden h-full flex flex-col p-8">
          <div class="flex justify-between items-center mb-4">
             <h2 class="text-sm font-semibold text-slate-500 uppercase tracking-wider">CSS</h2>
             <div class="flex gap-2">
               <button class="px-3 py-1.5 bg-white border border-slate-200 rounded text-[13px] font-medium text-slate-700 hover:bg-slate-50">Copy Selected</button>
               <button class="px-3 py-1.5 bg-blue-500 text-white rounded text-[13px] font-medium hover:bg-blue-600">Copy All</button>
             </div>
          </div>
          <div class="flex-1 overflow-auto rounded-lg [&_pre]:!bg-slate-900 [&_pre]:!p-6 [&_pre]:!h-full text-[13px]" id="css-output-container">
            <Code code={initialCSS} lang="css" theme="github-dark" />
          </div>
        </div>


      </main>

      <!-- Right Sidebar -->
      <aside id="right-sidebar" class="w-[280px] bg-[#f8f9fa] border-l border-slate-200 flex flex-col overflow-y-auto shrink-0 h-full">
        <div class="p-6 flex flex-col gap-8">

          <!-- Font Size -->
          <div>
            <div class="flex justify-between text-[11px] font-medium text-slate-700 mb-4">
              <span>Font Size</span>
              <span id="font-size-val">93</span>
            </div>
            <input type="range" id="font-size" min="12" max="200" value="93" class="w-full accent-slate-400 h-1 bg-slate-200 rounded-lg appearance-none cursor-pointer">
          </div>

          <!-- Preset Variations -->
          <div>
            <h2 class="text-[11px] font-bold text-slate-400 uppercase tracking-wider mb-3">Preset Variations</h2>
            <div class="flex flex-col gap-1" id="preset-variations">
              <button class="preset-btn flex justify-between items-center w-full px-2 py-1.5 hover:bg-slate-200 rounded text-left text-[13px] text-slate-900 transition-colors" data-weight="900" data-width="100" data-opsz="14">
                <span>Text Black Italic</span>
                <span class="font-bold italic text-base">Ag</span>
              </button>
              <button class="preset-btn flex justify-between items-center w-full px-2 py-1.5 hover:bg-slate-200 rounded text-left text-[13px] text-slate-900 transition-colors" data-weight="900" data-width="75" data-opsz="144">
                <span>Display Narrow Black Italic</span>
                <span class="font-bold italic tracking-tighter text-base">Ag</span>
              </button>
              <button class="preset-btn flex justify-between items-center w-full px-2 py-1.5 hover:bg-slate-200 rounded text-left text-[13px] text-slate-900 transition-colors" data-weight="900" data-width="50" data-opsz="14">
                <span>Text Condensed Black Italic</span>
                <span class="font-bold italic tracking-tight text-base">Ag</span>
              </button>
            </div>
          </div>

          <!-- Variable Options -->
          <div>
            <h2 class="text-[11px] font-bold text-slate-400 uppercase tracking-wider mb-3">Variable Options</h2>

            <!-- 2D Pad Placeholder -->
            <div class="w-full aspect-square border border-slate-200 bg-white rounded mb-6 relative">
               <div class="absolute right-0 top-1/4 w-3 h-3 rounded-full border-2 border-slate-500 bg-white -mr-1.5 -mt-1.5 cursor-grab"></div>
               <div class="absolute left-1/2 top-0 bottom-0 w-px bg-slate-100"></div>
               <div class="absolute top-1/2 left-0 right-0 h-px bg-slate-100"></div>
            </div>

            <div class="flex flex-col gap-6">
              <div>
                <div class="flex justify-between text-[11px] font-medium text-slate-700 mb-4 items-center">
                  <div class="flex items-center gap-1.5">
                    <svg class="w-3.5 h-3.5 text-slate-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 19V5a2 2 0 012-2h12a2 2 0 012 2v14M4 19l8-8 8 8"/></svg>
                    <span>Weight</span>
                  </div>
                  <span id="font-weight-val">708.50</span>
                </div>
                <input type="range" id="font-weight" min="100" max="900" step="1" value="708.5" class="w-full accent-slate-400 h-1 bg-slate-200 rounded-lg appearance-none cursor-pointer">
              </div>

              <div>
                <div class="flex justify-between text-[11px] font-medium text-slate-700 mb-4 items-center">
                  <div class="flex items-center gap-1.5">
                    <svg class="w-3.5 h-3.5 text-slate-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 8V5a2 2 0 00-2-2H5a2 2 0 00-2 2v3M21 16v3a2 2 0 01-2 2H5a2 2 0 01-2-2v-3M12 2v20M8 12h8"/></svg>
                    <span>Width</span>
                  </div>
                  <span id="font-width-val">66.88</span>
                </div>
                <input type="range" id="font-width" min="50" max="150" step="1" value="66.88" class="w-full accent-slate-400 h-1 bg-slate-200 rounded-lg appearance-none cursor-pointer">
              </div>

              <div>
                <div class="flex justify-between text-[11px] font-medium text-slate-700 mb-4 items-center">
                  <div class="flex items-center gap-1.5">
                    <svg class="w-3.5 h-3.5 text-slate-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><path d="M3 9h18M9 21V9"/></svg>
                    <span>Optical Size</span>
                  </div>
                  <span id="font-opsz-val">39.82</span>
                </div>
                <input type="range" id="font-opsz" min="8" max="144" step="1" value="39.82" class="w-full accent-slate-400 h-1 bg-slate-200 rounded-lg appearance-none cursor-pointer">
              </div>
            </div>

          </div>
        </div>
      </aside>
    </div>


    <style>
      .preview-text {
        font-family: var(--font-family);
        font-size: var(--font-size);
        font-weight: var(--font-weight);
        font-variation-settings: 'wght' var(--font-weight), 'wdth' var(--font-width), 'opsz' var(--font-opsz);
        outline: none;
      }

      /* Target editor.js blocks specifically to inherit the styles */
      #editorjs .ce-block__content {
        max-width: none; /* Let editor fill the container */
      }

      /* Make sure editor tools inherit the font styling */
      #editorjs h1,
      #editorjs h2,
      #editorjs h3,
      #editorjs h4,
      #editorjs h5,
      #editorjs h6,
      #editorjs p,
      #editorjs ul,
      #editorjs ol,
      #editorjs li {
         font-family: inherit;
         /* Don't strictly inherit size to allow headers to scale relatively,
            but give a baseline if we want the slider to control the overall body scale */
      }
    </style>

    <script>
      import EditorJS from '@editorjs/editorjs';
      import Header from '@editorjs/header';
      import List from '@editorjs/list';

      const editor = new EditorJS({
        holder: 'editorjs',
        tools: {
          header: Header,
          list: List
        },
        data: {
          blocks: [
            {
              type: "header",
              data: {
                text: "Typography Playground",
                level: 1
              }
            },
            {
              type: "paragraph",
              data: {
                text: "Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris nisi ut aliquip ex ea commodo consequat."
              }
            },
             {
              type: "paragraph",
              data: {
                text: "Duis aute irure dolor in reprehenderit in voluptate velit esse cillum dolore eu fugiat nulla pariatur. Excepteur sint occaecat cupidatat non proident, sunt in culpa qui officia deserunt mollit anim id est laborum."
              }
            },
            {
              type: "list",
              data: {
                style: "unordered",
                items: [
                   "Variable fonts are cool",
                   "They save bandwidth",
                   "They offer granular design control"
                ]
              }
            }
          ]
        }
      });

      const root = document.documentElement;

      // Initial Font Family
      let currentFontFamily = "'Google Sans', sans-serif";
      let currentFontName = "Google Sans";
      root.style.setProperty('--font-family', currentFontFamily);

      // Right Sidebar Controls
      const controls = {
        fontSize: document.getElementById('font-size') as HTMLInputElement,
        fontWeight: document.getElementById('font-weight') as HTMLInputElement,
        fontWidth: document.getElementById('font-width') as HTMLInputElement,
        fontOpsz: document.getElementById('font-opsz') as HTMLInputElement,
      };

      const values = {
        fontSize: document.getElementById('font-size-val'),
        fontWeight: document.getElementById('font-weight-val'),
        fontWidth: document.getElementById('font-width-val'),
        fontOpsz: document.getElementById('font-opsz-val'),
      };

      const cssOutputContainer = document.getElementById('css-output-container');

      function updateCSSOutput() {
        if (cssOutputContainer) {
            const preElement = cssOutputContainer.querySelector('pre');
            if (preElement) {
              const codeElement = preElement.querySelector('code');
              // We'll update the text content. Astro's Code component renders static HTML on server,
              // so updating it dynamically on client will lose the Shiki syntax highlighting,
              // but it will maintain the correct structure and bg color.
              // For a truly dynamic highlighted block we would need a client-side highlighter like prism or highlight.js,
              // but replacing the raw text in the pre/code block is sufficient for the preview.
              if (codeElement) {
                // simple span replacements to retain some fake highlighting colors for the dynamically updated values
                codeElement.innerHTML = `
<span class="line"><span style="color:#B392F0">.preview-text</span><span style="color:#E1E4E8"> {</span></span>
<span class="line"><span style="color:#E1E4E8">  </span><span style="color:#79B8FF">font-family</span><span style="color:#E1E4E8">: </span><span style="color:#9ECBFF">${currentFontFamily.replace(/'/g, '&#39;')}</span><span style="color:#E1E4E8">;</span></span>
<span class="line"><span style="color:#E1E4E8">  </span><span style="color:#79B8FF">font-size</span><span style="color:#E1E4E8">: </span><span style="color:#79B8FF">${controls.fontSize?.value || 93}px</span><span style="color:#E1E4E8">;</span></span>
<span class="line"><span style="color:#E1E4E8">  </span><span style="color:#79B8FF">font-variation-settings</span><span style="color:#E1E4E8">: </span><span style="color:#9ECBFF">&#39;wght&#39;</span><span style="color:#E1E4E8"> </span><span style="color:#79B8FF">${controls.fontWeight?.value || 400}</span><span style="color:#E1E4E8">, </span><span style="color:#9ECBFF">&#39;wdth&#39;</span><span style="color:#E1E4E8"> </span><span style="color:#79B8FF">${controls.fontWidth?.value || 100}</span><span style="color:#E1E4E8">, </span><span style="color:#9ECBFF">&#39;opsz&#39;</span><span style="color:#E1E4E8"> </span><span style="color:#79B8FF">${controls.fontOpsz?.value || 14}</span><span style="color:#E1E4E8">;</span></span>
<span class="line"><span style="color:#E1E4E8">}</span></span>`;
              }
            }
        }
      }

      function updateTypography() {
        // Update CSS variables
        if (controls.fontSize) root.style.setProperty('--font-size', `${controls.fontSize.value}px`);
        if (controls.fontWeight) root.style.setProperty('--font-weight', controls.fontWeight.value);
        if (controls.fontWidth) root.style.setProperty('--font-width', controls.fontWidth.value);
        if (controls.fontOpsz) root.style.setProperty('--font-opsz', controls.fontOpsz.value);

        // Update display values
        if (values.fontSize && controls.fontSize) values.fontSize.textContent = controls.fontSize.value;
        if (values.fontWeight && controls.fontWeight) values.fontWeight.textContent = parseFloat(controls.fontWeight.value).toFixed(2);
        if (values.fontWidth && controls.fontWidth) values.fontWidth.textContent = parseFloat(controls.fontWidth.value).toFixed(2);
        if (values.fontOpsz && controls.fontOpsz) values.fontOpsz.textContent = parseFloat(controls.fontOpsz.value).toFixed(2);

        updateCSSOutput();
      }

      // Add event listeners
      Object.values(controls).forEach(control => {
        if (control) {
          control.addEventListener('input', updateTypography);
        }
      });

      // Preset variations logic
      const presetVariations = document.getElementById('preset-variations');
      if (presetVariations) {
          const presetBtns = presetVariations.querySelectorAll('.preset-btn');
          presetBtns.forEach(btn => {
             btn.addEventListener('click', () => {
                const weight = btn.getAttribute('data-weight');
                const width = btn.getAttribute('data-width');
                const opsz = btn.getAttribute('data-opsz');

                if (weight && controls.fontWeight) controls.fontWeight.value = weight;
                if (width && controls.fontWidth) controls.fontWidth.value = width;
                if (opsz && controls.fontOpsz) controls.fontOpsz.value = opsz;

                updateTypography();
             });
          });
      }

      // Font Selection Logic
      const fontList = document.getElementById('font-list');
      if (fontList) {
        const fontItems = fontList.querySelectorAll('.font-item');
        const infoFontName = document.getElementById('info-font-name');
        const infoFontPreview = document.getElementById('info-font-preview');

        fontItems.forEach(item => {
          item.addEventListener('click', () => {
            // Update UI state for all items
            fontItems.forEach(i => {
              i.classList.remove('bg-white', 'border', 'border-blue-400', 'shadow-sm');
              i.classList.add('hover:bg-slate-100');
              const indicator = i.querySelector('.font-active-indicator');
              if (indicator) indicator.classList.add('hidden');

              const nameDisplay = i.querySelector('.font-name-display');
              if(nameDisplay) {
                 nameDisplay.classList.remove('text-slate-900');
                 nameDisplay.classList.add('text-slate-700', 'group-hover:text-slate-900');
              }
            });

            // Set active state for clicked item
            item.classList.add('bg-white', 'border', 'border-blue-400', 'shadow-sm');
            item.classList.remove('hover:bg-slate-100');
            const activeIndicator = item.querySelector('.font-active-indicator');
            if (activeIndicator) activeIndicator.classList.remove('hidden');

            const activeNameDisplay = item.querySelector('.font-name-display');
            if (activeNameDisplay) {
               activeNameDisplay.classList.remove('text-slate-700', 'group-hover:text-slate-900');
               activeNameDisplay.classList.add('text-slate-900');
            }

            // Update typography
            const newFont = item.getAttribute('data-font');
            const newName = item.getAttribute('data-name');
            if (newFont && newName) {
              currentFontFamily = newFont;
              currentFontName = newName;
              root.style.setProperty('--font-family', currentFontFamily);

              if (infoFontName) infoFontName.textContent = currentFontName;
              if (infoFontPreview) {
                infoFontPreview.textContent = currentFontName;
                infoFontPreview.style.fontFamily = currentFontFamily;
              }

              updateCSSOutput();
            }
          });
        });
      }

      // Initialize
      updateTypography();

      // Tab switching
      const topHeader = document.getElementById('top-header');
      if (topHeader) {
          const tabs = topHeader.querySelectorAll('button');
          const views = {
              'Design': document.getElementById('design-view'),
              'Code': document.getElementById('code-view'),
          };

          tabs.forEach(tab => {
              if (['Design', 'Code'].includes(tab.textContent || '')) {
                  tab.addEventListener('click', () => {
                      // Update active tab styling
                      tabs.forEach(t => {
                          if (['Design', 'Code'].includes(t.textContent || '')) {
                             t.className = 'hover:text-slate-900 transition-colors pb-[13px] pt-[15px] -mb-[2px] text-slate-400';
                          }
                      });
                      tab.className = 'text-slate-900 border-b-2 border-slate-900 pb-[13px] pt-[15px] -mb-[2px]';

                      // Show/hide views
                      Object.values(views).forEach(view => {
                          if (view) view.classList.add('hidden');
                      });

                      const selectedView = views[tab.textContent as keyof typeof views];
                      if (selectedView) {
                          if (tab.textContent === 'Code') {
                              selectedView.classList.replace('hidden', 'flex');
                          } else {
                              selectedView.classList.remove('hidden');
                          }
                      }
                  });
              }
          });
      }
    </script>
  </body>
</html>
