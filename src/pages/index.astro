---
import Layout from '../layouts/Layout.astro';
import LeftSidebar from '../components/LeftSidebar.astro';
import RightSidebar from '../components/RightSidebar.astro';
import EditorCanvas from '../components/EditorCanvas.astro';

const initialCSS = `
.preview-text {
  font-family: 'Google Sans', sans-serif;
}`;
---

<Layout>
  <div class="flex flex-col lg:flex-row h-screen overflow-hidden">
    <!-- Left Sidebar -->
    <LeftSidebar />

    <!-- Main Canvas -->
    <main id="main-area" class="flex-1 overflow-y-auto bg-white relative shadow-inner p-8 lg:p-12 order-3 lg:order-2">
      <EditorCanvas />
    </main>

    <!-- Right Sidebar -->
    <RightSidebar initialCSS={initialCSS} />
  </div>

  <style is:global>
    .preview-text {
      font-family: var(--font-family, 'Google Sans', sans-serif);
      outline: none;
    }
  </style>

  <script>
    const root = document.documentElement;

    // Initial Font Family
    let currentFontFamily = "'Google Sans', sans-serif";
    root.style.setProperty('--font-family', currentFontFamily);

    window.addEventListener('font-selected', ((event: CustomEvent) => {
      currentFontFamily = event.detail.fontFamily;
      root.style.setProperty('--font-family', currentFontFamily);
    }) as EventListener);
  </script>
</Layout>
