---
---
<div class="bg-[#2c2c2c] border border-[#333] rounded p-4 shadow-sm">
  <h3 class="text-xs font-bold text-gray-400 uppercase tracking-wider mb-3">Typography</h3>

  <div class="space-y-4" id="typography-controls">
     <!-- Font Size -->
     <div class="typo-control">
       <div class="flex justify-between items-center mb-1">
         <label for="typo-size" class="text-[11px] font-bold text-slate-400 uppercase">Size (px)</label>
         <input id="typo-size-input" type="number" value="16" min="8" max="144" class="w-12 bg-[#1e1e1e] border border-[#333] rounded px-1 py-0.5 text-[11px] text-white text-right focus:outline-none focus:border-blue-500 custom-number">
       </div>
       <input id="typo-size" type="range" min="8" max="144" value="16" step="1" class="w-full custom-range cursor-pointer">
     </div>

     <!-- Font Style -->
     <div class="typo-control">
       <label class="text-[11px] font-bold text-slate-400 uppercase mb-2 block">Font Style</label>
       <div class="flex bg-[#1e1e1e] rounded overflow-hidden border border-[#333]">
         <button class="fontstyle-btn flex-1 py-1 text-[11px] font-medium bg-[#3a3a3a] text-white border-r border-[#333] transition-colors" data-style="normal">Normal</button>
         <button class="fontstyle-btn flex-1 py-1 text-[11px] font-medium text-gray-400 hover:bg-[#2a2a2a] hover:text-white border-r border-[#333] transition-colors" data-style="italic">Italic</button>
         <button class="fontstyle-btn flex-1 py-1 text-[11px] font-medium text-gray-400 hover:bg-[#2a2a2a] hover:text-white transition-colors" data-style="oblique">Oblique</button>
       </div>
     </div>

     <!-- Line Height -->
     <div class="typo-control">
       <div class="flex justify-between items-center mb-1">
         <label for="typo-line-height" class="text-[11px] font-bold text-slate-400 uppercase">Line Height</label>
         <input id="typo-line-height-input" type="number" value="1.5" min="0.5" max="3" step="0.1" class="w-12 bg-[#1e1e1e] border border-[#333] rounded px-1 py-0.5 text-[11px] text-white text-right focus:outline-none focus:border-blue-500 custom-number">
       </div>
       <input id="typo-line-height" type="range" min="0.5" max="3" value="1.5" step="0.1" class="w-full custom-range cursor-pointer">
     </div>

     <!-- Letter Spacing -->
     <div class="typo-control">
       <div class="flex justify-between items-center mb-1">
         <label for="typo-letter-spacing" class="text-[11px] font-bold text-slate-400 uppercase">Letter Spacing (em)</label>
         <input id="typo-letter-spacing-input" type="number" value="0" min="-0.1" max="0.5" step="0.01" class="w-12 bg-[#1e1e1e] border border-[#333] rounded px-1 py-0.5 text-[11px] text-white text-right focus:outline-none focus:border-blue-500 custom-number">
       </div>
       <input id="typo-letter-spacing" type="range" min="-0.1" max="0.5" value="0" step="0.01" class="w-full custom-range cursor-pointer">
     </div>

     <!-- Word Spacing -->
     <div class="typo-control">
       <div class="flex justify-between items-center mb-1">
         <label for="typo-word-spacing" class="text-[11px] font-bold text-slate-400 uppercase">Word Spacing (em)</label>
         <input id="typo-word-spacing-input" type="number" value="0" min="-0.5" max="2" step="0.01" class="w-12 bg-[#1e1e1e] border border-[#333] rounded px-1 py-0.5 text-[11px] text-white text-right focus:outline-none focus:border-blue-500 custom-number">
       </div>
       <input id="typo-word-spacing" type="range" min="-0.5" max="2" value="0" step="0.01" class="w-full custom-range cursor-pointer">
     </div>

     <!-- Text Indent -->
     <div class="typo-control">
       <div class="flex justify-between items-center mb-1">
         <label for="typo-text-indent" class="text-[11px] font-bold text-slate-400 uppercase">Text Indent (px)</label>
         <input id="typo-text-indent-input" type="number" value="0" min="0" max="100" step="1" class="w-12 bg-[#1e1e1e] border border-[#333] rounded px-1 py-0.5 text-[11px] text-white text-right focus:outline-none focus:border-blue-500 custom-number">
       </div>
       <input id="typo-text-indent" type="range" min="0" max="100" value="0" step="1" class="w-full custom-range cursor-pointer">
     </div>

     <!-- Paragraph Spacing -->
     <div class="typo-control">
       <div class="flex justify-between items-center mb-1">
         <label for="typo-paragraph-spacing" class="text-[11px] font-bold text-slate-400 uppercase">Paragraph Spacing (em)</label>
         <input id="typo-paragraph-spacing-input" type="number" value="1" min="0" max="4" step="0.1" class="w-12 bg-[#1e1e1e] border border-[#333] rounded px-1 py-0.5 text-[11px] text-white text-right focus:outline-none focus:border-blue-500 custom-number">
       </div>
       <input id="typo-paragraph-spacing" type="range" min="0" max="4" value="1" step="0.1" class="w-full custom-range cursor-pointer">
     </div>

     <!-- Alignment -->
     <div>
       <div class="text-[11px] font-bold text-slate-400 uppercase mb-2">Alignment</div>
       <div class="flex gap-1 bg-[#1e1e1e] p-1 rounded border border-[#333]" id="typo-align-group">
         <button data-align="left" class="flex-1 py-1.5 flex justify-center items-center rounded bg-[#3a3a3a] text-white transition-colors align-btn text-[10px]" aria-label="Align Left">Left</button>
         <button data-align="center" class="flex-1 py-1.5 flex justify-center items-center rounded text-gray-400 hover:text-white hover:bg-[#2a2a2a] transition-colors align-btn text-[10px]" aria-label="Align Center">Center</button>
         <button data-align="right" class="flex-1 py-1.5 flex justify-center items-center rounded text-gray-400 hover:text-white hover:bg-[#2a2a2a] transition-colors align-btn text-[10px]" aria-label="Align Right">Right</button>
         <button data-align="justify" class="flex-1 py-1.5 flex justify-center items-center rounded text-gray-400 hover:text-white hover:bg-[#2a2a2a] transition-colors align-btn text-[10px]" aria-label="Align Justify">Justify</button>
       </div>
     </div>

     <!-- Text Color -->
     <div>
       <div class="text-[11px] font-bold text-slate-400 uppercase mb-2">Color</div>
       <div class="flex items-center gap-2">
           <input type="color" id="typo-color" value="#000000" class="w-8 h-8 rounded cursor-pointer bg-transparent border-0 p-0 shrink-0">
           <input type="text" id="typo-color-text" value="#000000" class="shrink-0 grow w-full bg-[#1e1e1e] border border-[#333] rounded px-2 py-1 text-sm text-white focus:outline-none focus:border-blue-500 uppercase">
       </div>
     </div>

     <!-- Text Transform -->
     <div>
       <div class="text-[11px] font-bold text-slate-400 uppercase mb-2">Text Transform</div>
       <div class="flex gap-1 bg-[#1e1e1e] p-1 rounded border border-[#333]" id="typo-transform-group">
         <button data-transform="none" class="flex-1 py-1.5 flex justify-center items-center rounded bg-[#3a3a3a] text-white transition-colors transform-btn text-[10px] font-bold uppercase tracking-wider" aria-label="None">None</button>
         <button data-transform="uppercase" class="flex-1 py-1.5 flex justify-center items-center rounded text-gray-400 hover:text-white hover:bg-[#2a2a2a] transition-colors transform-btn text-[10px] font-bold uppercase tracking-wider" aria-label="Uppercase">UP</button>
         <button data-transform="lowercase" class="flex-1 py-1.5 flex justify-center items-center rounded text-gray-400 hover:text-white hover:bg-[#2a2a2a] transition-colors transform-btn text-[10px] font-bold lowercase tracking-wider" aria-label="Lowercase">low</button>
         <button data-transform="capitalize" class="flex-1 py-1.5 flex justify-center items-center rounded text-gray-400 hover:text-white hover:bg-[#2a2a2a] transition-colors transform-btn text-[10px] font-bold capitalize tracking-wider" aria-label="Capitalize">Cap</button>
       </div>
     </div>

     <!-- Text Decoration -->
     <div>
       <div class="text-[11px] font-bold text-slate-400 uppercase mb-2">Text Decoration</div>
       <div class="flex gap-1 bg-[#1e1e1e] p-1 rounded border border-[#333]" id="typo-decoration-group">
         <button data-decoration="none" class="flex-1 py-1.5 flex justify-center items-center rounded bg-[#3a3a3a] text-white transition-colors decoration-btn text-[10px] font-bold uppercase tracking-wider" aria-label="None">None</button>
         <button data-decoration="underline" class="flex-1 py-1.5 flex justify-center items-center rounded text-gray-400 hover:text-white hover:bg-[#2a2a2a] transition-colors decoration-btn text-[10px] font-bold underline tracking-wider" aria-label="Underline">U</button>
         <button data-decoration="line-through" class="flex-1 py-1.5 flex justify-center items-center rounded text-gray-400 hover:text-white hover:bg-[#2a2a2a] transition-colors decoration-btn text-[10px] font-bold line-through tracking-wider" aria-label="Line Through">S</button>
       </div>
     </div>

  </div>
</div>
