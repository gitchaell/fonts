---
interface Props {
  fontFamily: string;
  fontName: string;
  isActive?: boolean;
}

const { fontFamily, fontName, isActive = false } = Astro.props;

const activeClasses = isActive
  ? 'bg-[#2c2c2c] border border-blue-500 shadow-sm'
  : 'hover:bg-[#2c2c2c] border border-transparent';

const indicatorClasses = isActive ? '' : 'hidden';
const textClasses = isActive ? 'text-white' : 'text-gray-400 group-hover:text-white';
---

<button class={`font-item w-full text-left p-2 rounded group relative ${activeClasses}`} data-font={fontFamily} data-name={fontName}>
  <div class={`absolute left-0 top-0 bottom-0 w-1 bg-blue-500 rounded-l font-active-indicator ${indicatorClasses}`}></div>
  <div class="flex justify-between items-center mb-1 pl-1">
    <span class={`text-[12px] font-medium font-name-display ${textClasses}`}>{fontName}</span>
    <div class="flex items-center text-gray-500 group-hover:text-gray-400 text-[10px]">
      <svg class="w-3 h-3 mr-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="6" cy="12" r="2"/><circle cx="18" cy="12" r="2"/><path d="M8 12h8"/></svg>
      1
    </div>
  </div>
  <div class="text-xl text-gray-200 pl-1 truncate" style={`font-family: ${fontFamily};`}>{fontName.replace('Google Sans ', 'Google ')}</div>
</button>
