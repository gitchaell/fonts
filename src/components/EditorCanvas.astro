---

<div id="design-view" class="px-12 flex flex-col gap-8 pb-32 pt-12">
  <div id="editorjs" class="preview-text"></div>
</div>

<script>
  import EditorJS from '@editorjs/editorjs';
  import Header from '@editorjs/header';
  import List from '@editorjs/list';
  import editorjsCodecup from '@calumk/editorjs-codecup';
  import Underline from '@editorjs/underline';
  import InlineCode from '@editorjs/inline-code';
  import Checklist from '@editorjs/checklist';
  import Quote from '@editorjs/quote';

  const defaultData = {
      blocks: [
        {
          type: "header",
          data: {
            text: "Typography Playground",
            level: 1
          }
        },
        {
          type: "paragraph",
          data: {
            text: "Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris nisi ut aliquip ex ea commodo consequat."
          }
        },
        {
          type: "list",
          data: {
            style: "unordered",
            items: [
               "Select a font from the left panel",
               "Write rich text right here",
               "Include code snippets"
            ]
          }
        },
        {
          type: "code",
          data: {
            code: "function helloWorld() {\n  console.log('Typography is awesome!');\n}",
            language: 'javascript'
          }
        },
        {
          type: "quote",
          data: {
            text: "The details are not the details. They make the design.",
            caption: "Charles Eames",
            alignment: "left"
          }
        }
      ]
  };

  const savedData = localStorage.getItem('editorjsData');
  const initialData = savedData ? JSON.parse(savedData) : defaultData;

  const editor = new EditorJS({
    holder: 'editorjs',
    tools: {
      header: {
          class: Header,
          inlineToolbar: ['link', 'bold', 'italic', 'underline']
      },
      list: {
          class: List,
          inlineToolbar: true
      },
      code: editorjsCodecup,
      underline: Underline,
      inlineCode: InlineCode,
      checklist: {
        class: Checklist,
        inlineToolbar: true,
      },
      quote: {
        class: Quote,
        inlineToolbar: true,
        shortcut: 'CMD+SHIFT+O',
        config: {
          quotePlaceholder: 'Enter a quote',
          captionPlaceholder: 'Quote\'s author',
        },
      }
    },
    data: initialData,
    onChange: (api, event) => {
        editor.save().then((outputData) => {
           localStorage.setItem('editorjsData', JSON.stringify(outputData));
        }).catch((error) => {
           console.log('Saving failed: ', error);
        });
    }
  });

  // Listen for font changes from the sidebar
  window.addEventListener('font-selected', ((event: CustomEvent) => {
    const root = document.documentElement;
    root.style.setProperty('--font-family', event.detail.fontFamily);
  }) as EventListener);
</script>

<style is:global>
  /* Target editor.js blocks specifically to inherit the styles */
  #editorjs .ce-block__content,
  #editorjs .ce-toolbar__content {
    max-width: 100%; /* Let editor fill the container without overflowing */
  }

  /* Make sure editor tools inherit the font styling */
  #editorjs h1,
  #editorjs h2,
  #editorjs h3,
  #editorjs h4,
  #editorjs h5,
  #editorjs h6,
  #editorjs p,
  #editorjs ul,
  #editorjs ol,
  #editorjs li,
  #editorjs code,
  #editorjs pre,
  #editorjs .cdx-checklist {
     font-family: inherit;
  }

  /* Restore heading/list styles overridden by Tailwind */
  #editorjs h1 {
      font-size: 2.25em;
      font-weight: 700;
      margin-top: 1em;
      margin-bottom: 0.5em;
      line-height: 1.2;
  }
  #editorjs h2 {
      font-size: 1.875em;
      font-weight: 700;
      margin-top: 1em;
      margin-bottom: 0.5em;
      line-height: 1.3;
  }
  #editorjs h3 {
      font-size: 1.5em;
      font-weight: 700;
      margin-top: 1em;
      margin-bottom: 0.5em;
      line-height: 1.4;
  }
  #editorjs h4 {
      font-size: 1.25em;
      font-weight: 700;
      margin-top: 1em;
      margin-bottom: 0.5em;
      line-height: 1.5;
  }
  #editorjs h5 {
      font-size: 1.125em;
      font-weight: 700;
      margin-top: 1em;
      margin-bottom: 0.5em;
      line-height: 1.6;
  }
  #editorjs h6 {
      font-size: 1em;
      font-weight: 700;
      margin-top: 1em;
      margin-bottom: 0.5em;
      line-height: 1.6;
  }
  #editorjs p {
      font-size: 1.1em;
      line-height: 1.6;
  }
  #editorjs ul {
      list-style-type: disc;
      padding-left: 2em;
      margin-bottom: 1em;
      font-size: 1.1em;
      line-height: 1.6;
  }
  #editorjs ol {
      list-style-type: decimal;
      padding-left: 2em;
      margin-bottom: 1em;
      font-size: 1.1em;
      line-height: 1.6;
  }

  /* highlight.js theme for editor code blocks */
  @import 'highlight.js/styles/github-dark.css';
</style>