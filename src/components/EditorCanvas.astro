---

<div id="design-view" class="px-12 flex flex-col gap-8 pb-32 pt-12">
  <div id="editorjs" class="preview-text"></div>
</div>

<script>
  import EditorJS from '@editorjs/editorjs';
  import Header from '@editorjs/header';
  import List from '@editorjs/list';
  import Underline from '@editorjs/underline';
  import Checklist from '@editorjs/checklist';

  const defaultData = {
      blocks: [
        {
          type: "header",
          data: {
            text: "The Art of Typography",
            level: 1
          }
        },
        {
          type: "paragraph",
          data: {
            text: "Typography is not just about making words legible; it's about giving them a voice. A well-designed font incorporates standard ligatures like <b>fi</b>, <b>fl</b>, and <b>ffi</b> to prevent ugly collisions between characters. When you activate discretionary ligatures, combinations like <b>st</b> and <b>ct</b> might connect in historical or decorative ways."
          }
        },
        {
          type: "header",
          data: {
            text: "Numerics: Fractions & Figures",
            level: 2
          }
        },
        {
          type: "paragraph",
          data: {
            text: "Data deserves to be beautiful. Lining figures (0123456789) align perfectly with capital letters, while oldstyle figures (0123456789) blend seamlessly into lowercase text. With tabular figures, columns of numbers like $12,345.67 and $89,012.34 align perfectly. You can also generate beautiful fractions like 1/2, 3/4, or even 7/8 with a single toggle."
          }
        },
        {
          type: "header",
          data: {
            text: "Capitals, Small Caps, & Positioning",
            level: 2
          }
        },
        {
          type: "paragraph",
          data: {
            text: "Small capitals (SMALL CAPS) are perfect for acronyms like NASA or HTML without overpowering the text. For mathematical or scientific notation, OpenType handles superscripts (x2 + y2 = z2) and subscripts (H2O) with precise positioning, eliminating the need for crude HTML tags."
          }
        },
        {
          type: "header",
          data: {
            text: "Contextual & Stylistic Sets",
            level: 2
          }
        },
        {
          type: "paragraph",
          data: {
            text: "Contextual alternates completely change how characters connect depending on their neighbors (e.g., -> turning into an arrow). Many modern variable fonts also provide Stylistic Sets (ss01, ss02) that completely alter the mood of the text by swapping out alternate character designs."
          }
        }
      ]
  };

  const savedData = localStorage.getItem('editorjsData_v2');
  const initialData = savedData ? JSON.parse(savedData) : defaultData;

  const editor = new EditorJS({
    holder: 'editorjs',
    tools: {
      header: {
          class: Header,
          inlineToolbar: ['link', 'bold', 'italic', 'underline']
      },
      list: {
          class: List,
          inlineToolbar: true
      },
      underline: Underline,
      checklist: {
        class: Checklist,
        inlineToolbar: true,
      }
    },
    data: initialData,
    onChange: () => {
        editor.save().then((outputData) => {
           localStorage.setItem('editorjsData_v2', JSON.stringify(outputData));
        }).catch((error) => {
           console.log('Saving failed: ', error);
        });
    }
  });

  // Listen for font changes from the sidebar
  window.addEventListener('font-selected', (e) => {
    const event = e as CustomEvent;
    const root = document.documentElement;
    root.style.setProperty('--font-family', event.detail.fontFamily);
  });

  window.addEventListener('axes-changed', (e) => {
    const event = e as CustomEvent;
    const root = document.documentElement;
    if (event.detail) {
       root.style.setProperty('--font-feature-settings', event.detail.features || 'normal');
       root.style.setProperty('--font-variation-settings', event.detail.settings || 'normal');
    }
  });

  window.addEventListener('typography-changed', (e) => {
    const event = e as CustomEvent;
    const root = document.documentElement;
    if (event.detail) {
      if (event.detail.fontSize) root.style.setProperty('--font-size', event.detail.fontSize);
      if (event.detail.lineHeight) root.style.setProperty('--line-height', event.detail.lineHeight);
      if (event.detail.letterSpacing) root.style.setProperty('--letter-spacing', event.detail.letterSpacing);
      if (event.detail.wordSpacing) root.style.setProperty('--word-spacing', event.detail.wordSpacing);
      if (event.detail.textAlign) root.style.setProperty('--text-align', event.detail.textAlign);
      if (event.detail.color) root.style.setProperty('--text-color', event.detail.color);
      if (event.detail.textTransform) root.style.setProperty('--text-transform', event.detail.textTransform);
      if (event.detail.textDecoration) root.style.setProperty('--text-decoration', event.detail.textDecoration);
      if (event.detail.fontStyle) root.style.setProperty('--font-style', event.detail.fontStyle);
      if (event.detail.textIndent) root.style.setProperty('--text-indent', event.detail.textIndent);
      if (event.detail.paragraphSpacing) root.style.setProperty('--paragraph-spacing', event.detail.paragraphSpacing);
    }
  });
</script>

<style is:global>
  #editorjs {
    font-feature-settings: var(--font-feature-settings, normal);
    font-variation-settings: var(--font-variation-settings, normal);
    font-size: var(--font-size, 16px);
    line-height: var(--line-height, 1.5);
    letter-spacing: var(--letter-spacing, 0em);
    word-spacing: var(--word-spacing, 0em);
    text-align: var(--text-align, left);
    color: var(--text-color, #000000);
    text-transform: var(--text-transform, none);
    text-decoration: var(--text-decoration, none);
    font-style: var(--font-style, normal);
  }

  /* Target editor.js blocks specifically to inherit the styles */
  #editorjs .ce-block__content,
  #editorjs .ce-toolbar__content {
    max-width: 100%; /* Let editor fill the container without overflowing */
  }

  /* Make sure editor tools inherit the font styling */
  #editorjs h1,
  #editorjs h2,
  #editorjs h3,
  #editorjs h4,
  #editorjs h5,
  #editorjs h6,
  #editorjs p,
  #editorjs ul,
  #editorjs ol,
  #editorjs li,
  #editorjs .cdx-checklist {
     font-family: inherit;
     /* Don't override font-size and line-height here to allow em scaling on headings */
     letter-spacing: var(--letter-spacing, inherit);
     word-spacing: var(--word-spacing, inherit);
     text-align: var(--text-align, inherit);
     color: var(--text-color, inherit);
     text-transform: var(--text-transform, inherit);
     text-decoration: var(--text-decoration, inherit);
     font-style: var(--font-style, inherit);
     font-feature-settings: inherit;
     font-variation-settings: inherit;
  }

  #editorjs p {
      font-size: 1.1em;
      line-height: 1.6;
      text-indent: var(--text-indent, 0);
      margin-bottom: var(--paragraph-spacing, 1em);
  }

  #editorjs h1,
  #editorjs h2,
  #editorjs h3,
  #editorjs h4,
  #editorjs h5,
  #editorjs h6 {
      margin-bottom: var(--paragraph-spacing, 0.5em);
  }

  /* Restore heading/list styles overridden by Tailwind */
  #editorjs h1 {
      font-size: 2.25em;
      font-weight: 700;
      margin-top: 1em;
      margin-bottom: 0.5em;
      line-height: 1.2;
  }
  #editorjs h2 {
      font-size: 1.875em;
      font-weight: 700;
      margin-top: 1em;
      margin-bottom: 0.5em;
      line-height: 1.3;
  }
  #editorjs h3 {
      font-size: 1.5em;
      font-weight: 700;
      margin-top: 1em;
      margin-bottom: 0.5em;
      line-height: 1.4;
  }
  #editorjs h4 {
      font-size: 1.25em;
      font-weight: 700;
      margin-top: 1em;
      margin-bottom: 0.5em;
      line-height: 1.5;
  }
  #editorjs h5 {
      font-size: 1.125em;
      font-weight: 700;
      margin-top: 1em;
      margin-bottom: 0.5em;
      line-height: 1.6;
  }
  #editorjs h6 {
      font-size: 1em;
      font-weight: 700;
      margin-top: 1em;
      margin-bottom: 0.5em;
      line-height: 1.6;
  }
  #editorjs ul {
      list-style-type: disc;
      padding-left: 2em;
      margin-bottom: 1em;
      font-size: 1.1em;
      line-height: 1.6;
  }
  #editorjs ol {
      list-style-type: decimal;
      padding-left: 2em;
      margin-bottom: 1em;
      font-size: 1.1em;
      line-height: 1.6;
  }
</style>