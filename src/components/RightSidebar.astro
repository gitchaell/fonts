---
import { Code } from 'astro:components';
import { AlignLeft, AlignCenter, AlignRight, AlignJustify } from '@lucide/astro';
import { defaultFont } from '../config/fonts';

interface Props {
  initialCSS: string;
}

const { initialCSS } = Astro.props;
---
<aside id="right-sidebar" class="w-full lg:w-[320px] lg:h-screen bg-[#1e1e1e] border-t lg:border-t-0 lg:border-l border-[#333] flex flex-col overflow-y-auto shrink-0 z-10 order-2 lg:order-3">
  <div class="p-6 flex flex-col gap-8 h-full">

    <div>
      <h2 class="text-[11px] font-bold text-slate-400 uppercase tracking-wider mb-4">Font Details</h2>
      <div class="bg-[#2c2c2c] border border-[#333] rounded p-4 shadow-sm mb-6">
        <h3 class="text-xl font-bold text-white mb-1" id="details-font-name">{defaultFont.fontName}</h3>
        <p class="text-[13px] text-gray-400 mb-4" id="details-font-type">{defaultFont.type}</p>

        <div class="space-y-4" id="details-axes">
           {defaultFont.axes.map(axis => (
             <div class="axis-control" data-axis={axis.tag}>
               <div class="flex justify-between items-center mb-1">
                 <label for={`axis-${axis.tag}`} class="text-[11px] font-bold text-slate-400 uppercase">{axis.name} ({axis.tag})</label>
                 <span class="text-[12px] font-medium text-gray-300 axis-value">{axis.default}</span>
               </div>
               <input id={`axis-${axis.tag}`} type="range" min={axis.min} max={axis.max} value={axis.default} step="1" class="w-full accent-blue-500 cursor-pointer h-1.5 bg-gray-600 rounded-lg appearance-none">
             </div>
           ))}
        </div>
      </div>


      <!-- Typography Section -->
      <div class="bg-[#2c2c2c] border border-[#333] rounded p-4 shadow-sm mb-6">
        <h3 class="text-xs font-bold text-gray-400 uppercase tracking-wider mb-3">Typography</h3>

        <div class="space-y-4" id="typography-controls">
           <!-- Font Size -->
           <div class="typo-control">
             <div class="flex justify-between items-center mb-1">
               <label for="typo-size" class="text-[11px] font-bold text-slate-400 uppercase">Size (px)</label>
               <input id="typo-size-input" type="number" value="16" min="8" max="144" class="w-12 bg-[#1e1e1e] border border-[#333] rounded px-1 py-0.5 text-[11px] text-white text-right focus:outline-none focus:border-blue-500">
             </div>
             <input id="typo-size" type="range" min="8" max="144" value="16" step="1" class="w-full accent-blue-500 cursor-pointer h-1.5 bg-gray-600 rounded-lg appearance-none">
           </div>

           <!-- Line Height -->
           <div class="typo-control">
             <div class="flex justify-between items-center mb-1">
               <label for="typo-line-height" class="text-[11px] font-bold text-slate-400 uppercase">Line Height</label>
               <input id="typo-line-height-input" type="number" value="1.5" min="0.5" max="3" step="0.1" class="w-12 bg-[#1e1e1e] border border-[#333] rounded px-1 py-0.5 text-[11px] text-white text-right focus:outline-none focus:border-blue-500">
             </div>
             <input id="typo-line-height" type="range" min="0.5" max="3" value="1.5" step="0.1" class="w-full accent-blue-500 cursor-pointer h-1.5 bg-gray-600 rounded-lg appearance-none">
           </div>

           <!-- Letter Spacing -->
           <div class="typo-control">
             <div class="flex justify-between items-center mb-1">
               <label for="typo-letter-spacing" class="text-[11px] font-bold text-slate-400 uppercase">Letter Spacing (em)</label>
               <input id="typo-letter-spacing-input" type="number" value="0" min="-0.1" max="0.5" step="0.01" class="w-12 bg-[#1e1e1e] border border-[#333] rounded px-1 py-0.5 text-[11px] text-white text-right focus:outline-none focus:border-blue-500">
             </div>
             <input id="typo-letter-spacing" type="range" min="-0.1" max="0.5" value="0" step="0.01" class="w-full accent-blue-500 cursor-pointer h-1.5 bg-gray-600 rounded-lg appearance-none">
           </div>

           <!-- Alignment -->
           <div>
             <div class="text-[11px] font-bold text-slate-400 uppercase mb-2">Alignment</div>
             <div class="flex gap-1 bg-[#1e1e1e] p-1 rounded border border-[#333]" id="typo-align-group">
               <button data-align="left" class="flex-1 py-1.5 flex justify-center items-center rounded bg-[#3a3a3a] text-white transition-colors align-btn" aria-label="Align Left"><AlignLeft class="w-4 h-4" /></button>
               <button data-align="center" class="flex-1 py-1.5 flex justify-center items-center rounded text-gray-400 hover:text-white hover:bg-[#2a2a2a] transition-colors align-btn" aria-label="Align Center"><AlignCenter class="w-4 h-4" /></button>
               <button data-align="right" class="flex-1 py-1.5 flex justify-center items-center rounded text-gray-400 hover:text-white hover:bg-[#2a2a2a] transition-colors align-btn" aria-label="Align Right"><AlignRight class="w-4 h-4" /></button>
               <button data-align="justify" class="flex-1 py-1.5 flex justify-center items-center rounded text-gray-400 hover:text-white hover:bg-[#2a2a2a] transition-colors align-btn" aria-label="Align Justify"><AlignJustify class="w-4 h-4" /></button>
             </div>
           </div>

           <!-- Text Color -->
           <div>
             <div class="text-[11px] font-bold text-slate-400 uppercase mb-2">Color</div>
             <div class="flex items-center gap-2">
                 <input type="color" id="typo-color" value="#000000" class="w-8 h-8 rounded cursor-pointer bg-transparent border-0 p-0">
                 <input type="text" id="typo-color-text" value="#000000" class="flex-1 bg-[#1e1e1e] border border-[#333] rounded px-2 py-1 text-sm text-white focus:outline-none focus:border-blue-500 uppercase">
             </div>
           </div>

        </div>
      </div>

      <div class="bg-[#2c2c2c] border border-[#333] rounded p-4 shadow-sm mb-6">
        <h3 class="text-xs font-bold text-gray-400 uppercase tracking-wider mb-3">Font Features</h3>

        <div class="space-y-4" id="font-features-container">
           <!-- Ligatures -->
           <div>
              <div class="text-[11px] font-bold text-gray-500 uppercase mb-2">Ligatures</div>

              <label class="flex items-center justify-between cursor-pointer group mb-2">
                 <div class="flex items-center gap-3">
                    <div class="relative">
                       <input type="checkbox" class="sr-only peer feature-toggle" data-feature="liga">
                       <div class="w-8 h-4 bg-gray-600 rounded-full peer peer-checked:after:translate-x-full peer-checked:bg-blue-500 after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:rounded-full after:h-3 after:w-3 after:transition-all"></div>
                    </div>
                    <span class="text-[13px] text-gray-300 group-hover:text-white transition-colors">Standard Ligatures (liga)</span>
                 </div>
                 <span class="text-lg text-gray-400 feature-preview" style="font-feature-settings: 'liga' 1;">fi</span>
              </label>

              <label class="flex items-center justify-between cursor-pointer group mb-2">
                 <div class="flex items-center gap-3">
                    <div class="relative">
                       <input type="checkbox" class="sr-only peer feature-toggle" data-feature="dlig">
                       <div class="w-8 h-4 bg-gray-600 rounded-full peer peer-checked:after:translate-x-full peer-checked:bg-blue-500 after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:rounded-full after:h-3 after:w-3 after:transition-all"></div>
                    </div>
                    <span class="text-[13px] text-gray-300 group-hover:text-white transition-colors">Discretionary (dlig)</span>
                 </div>
                 <span class="text-lg text-gray-400 feature-preview" style="font-feature-settings: 'dlig' 1;">ct</span>
              </label>
           </div>

           <!-- Numerics -->
           <div>
              <div class="text-[11px] font-bold text-gray-500 uppercase mb-2">Numerics</div>

              <label class="flex items-center justify-between cursor-pointer group mb-2">
                 <div class="flex items-center gap-3">
                    <div class="relative">
                       <input type="checkbox" class="sr-only peer feature-toggle" data-feature="frac">
                       <div class="w-8 h-4 bg-gray-600 rounded-full peer peer-checked:after:translate-x-full peer-checked:bg-blue-500 after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:rounded-full after:h-3 after:w-3 after:transition-all"></div>
                    </div>
                    <span class="text-[13px] text-gray-300 group-hover:text-white transition-colors">Fractions (frac)</span>
                 </div>
                 <span class="text-lg text-gray-400 feature-preview" style="font-feature-settings: 'frac' 1;">1/2</span>
              </label>

              <label class="flex items-center justify-between cursor-pointer group mb-2">
                 <div class="flex items-center gap-3">
                    <div class="relative">
                       <input type="checkbox" class="sr-only peer feature-toggle" data-feature="tnum">
                       <div class="w-8 h-4 bg-gray-600 rounded-full peer peer-checked:after:translate-x-full peer-checked:bg-blue-500 after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:rounded-full after:h-3 after:w-3 after:transition-all"></div>
                    </div>
                    <span class="text-[13px] text-gray-300 group-hover:text-white transition-colors">Tabular Figures (tnum)</span>
                 </div>
                 <span class="text-lg text-gray-400 feature-preview" style="font-feature-settings: 'tnum' 1;">00</span>
              </label>
           </div>

           <div>
              <label for="font-feature-settings-input" class="text-[11px] font-bold text-gray-500 uppercase mb-2 block">Manual Features</label>
              <input type="text" id="font-feature-settings-input" placeholder="e.g. 'ss01' 1, 'swsh' 1" class="w-full bg-[#1e1e1e] border border-[#333] rounded px-3 py-2 text-sm text-white placeholder-gray-500 focus:outline-none focus:border-blue-500 transition-colors">
           </div>
        </div>
      </div>
    </div>

    <!-- Output Section -->
    <div class="mt-auto">
      <div class="flex justify-between items-center mb-4">
        <h2 class="text-[11px] font-bold text-slate-400 uppercase tracking-wider">CSS Output</h2>
        <button id="copy-css-btn" class="text-[11px] font-medium text-blue-400 hover:text-blue-300 transition-colors flex items-center gap-1 overflow-hidden relative h-4 w-16" aria-label="Copy CSS">
           <span id="copy-text" class="absolute inset-0 flex items-center transition-transform duration-300">
              <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
              Copy
           </span>
           <span id="copied-text" class="absolute inset-0 flex items-center text-green-400 transition-transform duration-300 translate-y-full">
              <svg class="w-3 h-3 mr-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"></polyline></svg>
              Copied!
           </span>
        </button>
      </div>

      <div id="css-output-container" class="bg-[#1a1b26] rounded border border-[#333] p-4 text-[12px] font-mono overflow-x-auto shadow-inner mb-6">
        <Code code={initialCSS} lang="css" theme="github-dark" />
      </div>

      <button id="download-font-btn" class="w-full bg-blue-600 hover:bg-blue-700 text-white font-medium py-2.5 px-4 rounded transition-colors flex items-center justify-center gap-2 relative overflow-hidden" aria-label="Download Font">
        <span id="download-text" class="flex items-center gap-2 transition-transform duration-300">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
          Get Font
        </span>
        <span id="downloaded-text" class="absolute inset-0 flex items-center justify-center text-white transition-transform duration-300 translate-y-full">
          <svg class="w-4 h-4 mr-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"></polyline></svg>
          Downloading...
        </span>
      </button>
    </div>
  </div>
</aside>

<script>
  import { fonts, defaultFont } from '../config/fonts';

  let currentFontConfig = defaultFont;

  function getVariationSettingsStr() {
    const activeAxes = document.querySelectorAll('.axis-control');
    if(activeAxes.length === 0) return 'normal';

    let settings: string[] = [];
    activeAxes.forEach(control => {
      const axis = control.getAttribute('data-axis');
      const input = control.querySelector('input');
      if (axis && input) {
        settings.push(`'${axis}' ${input.value}`);
      }
    });
    return settings.join(', ');
  }

  function getFontFaceStr() {
    return currentFontConfig.fontFace;
  }


  let typoState = {
    fontSize: '16px',
    lineHeight: '1.5',
    letterSpacing: '0em',
    textAlign: 'left',
    color: '#000000'
  };

  function dispatchTypographyChange() {
    window.dispatchEvent(new CustomEvent('typography-changed', {
      detail: typoState
    }));
    updateCSSOutput();
  }

  function setupTypographyListeners() {
    // Font Size
    const sizeRange = document.getElementById('typo-size') as HTMLInputElement;
    const sizeInput = document.getElementById('typo-size-input') as HTMLInputElement;
    if (sizeRange && sizeInput) {
      const updateSize = (val: string) => {
        sizeRange.value = val;
        sizeInput.value = val;
        typoState.fontSize = `${val}px`;
        dispatchTypographyChange();
      };
      sizeRange.addEventListener('input', (e) => updateSize((e.target as HTMLInputElement).value));
      sizeInput.addEventListener('input', (e) => updateSize((e.target as HTMLInputElement).value));
    }

    // Line Height
    const lhRange = document.getElementById('typo-line-height') as HTMLInputElement;
    const lhInput = document.getElementById('typo-line-height-input') as HTMLInputElement;
    if (lhRange && lhInput) {
      const updateLH = (val: string) => {
        lhRange.value = val;
        lhInput.value = val;
        typoState.lineHeight = val;
        dispatchTypographyChange();
      };
      lhRange.addEventListener('input', (e) => updateLH((e.target as HTMLInputElement).value));
      lhInput.addEventListener('input', (e) => updateLH((e.target as HTMLInputElement).value));
    }

    // Letter Spacing
    const lsRange = document.getElementById('typo-letter-spacing') as HTMLInputElement;
    const lsInput = document.getElementById('typo-letter-spacing-input') as HTMLInputElement;
    if (lsRange && lsInput) {
      const updateLS = (val: string) => {
        lsRange.value = val;
        lsInput.value = val;
        typoState.letterSpacing = `${val}em`;
        dispatchTypographyChange();
      };
      lsRange.addEventListener('input', (e) => updateLS((e.target as HTMLInputElement).value));
      lsInput.addEventListener('input', (e) => updateLS((e.target as HTMLInputElement).value));
    }

    // Text Color
    const colorPicker = document.getElementById('typo-color') as HTMLInputElement;
    const colorText = document.getElementById('typo-color-text') as HTMLInputElement;
    if (colorPicker && colorText) {
      const updateColor = (val: string) => {
        colorPicker.value = val;
        colorText.value = val;
        typoState.color = val;
        dispatchTypographyChange();
      };
      colorPicker.addEventListener('input', (e) => updateColor((e.target as HTMLInputElement).value));
      colorText.addEventListener('input', (e) => {
        const val = (e.target as HTMLInputElement).value;
        if (/^#[0-9A-F]{6}$/i.test(val) || /^#[0-9A-F]{3}$/i.test(val)) {
            updateColor(val);
        }
      });
    }

    // Alignment
    const alignBtns = document.querySelectorAll('.align-btn');
    alignBtns.forEach(btn => {
      btn.addEventListener('click', (e) => {
        const target = e.currentTarget as HTMLElement;
        const align = target.getAttribute('data-align');
        if (align) {
          // Update active states
          alignBtns.forEach(b => {
            b.classList.remove('bg-[#3a3a3a]', 'text-white');
            b.classList.add('text-gray-400', 'hover:bg-[#2a2a2a]', 'hover:text-white');
          });
          target.classList.remove('text-gray-400', 'hover:bg-[#2a2a2a]', 'hover:text-white');
          target.classList.add('bg-[#3a3a3a]', 'text-white');

          typoState.textAlign = align;
          dispatchTypographyChange();
        }
      });
    });
  }


  function updateCSSOutput() {
    const cssOutputContainer = document.getElementById('css-output-container');
    if (cssOutputContainer) {
        const codeElement = cssOutputContainer.querySelector('code');
        if (codeElement) {
          const settingsStr = getVariationSettingsStr();
          const fontFaceStr = getFontFaceStr();
          const featureSettingsStr = getFontFeatureSettingsStr();

          // Escape HTML characters for the code block display
          const escapedFontFace = fontFaceStr
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .split('\n')
            .map(line => `<span class="line"><span style="color:#E1E4E8">${line}</span></span>`)
            .join('\n');

          codeElement.innerHTML = `
${escapedFontFace}
<span class="line"><span style="color:#B392F0">.preview-text</span><span style="color:#E1E4E8"> {</span></span>
<span class="line"><span style="color:#E1E4E8">  </span><span style="color:#79B8FF">font-family</span><span style="color:#E1E4E8">: </span><span style="color:#9ECBFF">${currentFontConfig.fontFamily.replace(/'/g, '&#39;')}</span><span style="color:#E1E4E8">;</span></span>
<span class="line"><span style="color:#E1E4E8">  </span><span style="color:#79B8FF">font-size</span><span style="color:#E1E4E8">: </span><span style="color:#9ECBFF">${typoState.fontSize}</span><span style="color:#E1E4E8">;</span></span>
<span class="line"><span style="color:#E1E4E8">  </span><span style="color:#79B8FF">line-height</span><span style="color:#E1E4E8">: </span><span style="color:#9ECBFF">${typoState.lineHeight}</span><span style="color:#E1E4E8">;</span></span>
<span class="line"><span style="color:#E1E4E8">  </span><span style="color:#79B8FF">letter-spacing</span><span style="color:#E1E4E8">: </span><span style="color:#9ECBFF">${typoState.letterSpacing}</span><span style="color:#E1E4E8">;</span></span>
<span class="line"><span style="color:#E1E4E8">  </span><span style="color:#79B8FF">text-align</span><span style="color:#E1E4E8">: </span><span style="color:#9ECBFF">${typoState.textAlign}</span><span style="color:#E1E4E8">;</span></span>
<span class="line"><span style="color:#E1E4E8">  </span><span style="color:#79B8FF">color</span><span style="color:#E1E4E8">: </span><span style="color:#9ECBFF">${typoState.color}</span><span style="color:#E1E4E8">;</span></span>
<span class="line"><span style="color:#E1E4E8">  </span><span style="color:#79B8FF">font-variation-settings</span><span style="color:#E1E4E8">: </span><span style="color:#9ECBFF">${settingsStr}</span><span style="color:#E1E4E8">;</span></span>
<span class="line"><span style="color:#E1E4E8">  </span><span style="color:#79B8FF">font-feature-settings</span><span style="color:#E1E4E8">: </span><span style="color:#9ECBFF">${featureSettingsStr}</span><span style="color:#E1E4E8">;</span></span>
<span class="line"><span style="color:#E1E4E8">}</span></span>`;
        }
    }
  }

  function getFontFeatureSettingsStr() {
    const toggles = document.querySelectorAll('.feature-toggle') as NodeListOf<HTMLInputElement>;
    const features: string[] = [];

    toggles.forEach(toggle => {
      if (toggle.checked) {
        const feature = toggle.getAttribute('data-feature');
        if (feature) features.push(`'${feature}' 1`);
      }
    });

    const input = document.getElementById('font-feature-settings-input') as HTMLInputElement;
    if (input && input.value.trim() !== '') {
      // Split by comma and add any manual features
      const manualFeatures = input.value.split(',').map(f => f.trim()).filter(f => f);
      features.push(...manualFeatures);
    }

    return features.length > 0 ? features.join(', ') : 'normal';
  }

  function dispatchAxesChange() {
    const settingsStr = getVariationSettingsStr();
    window.dispatchEvent(new CustomEvent('axes-changed', {
      detail: { settings: settingsStr, features: getFontFeatureSettingsStr() }
    }));
    updateCSSOutput();
  }

  function setupSliderListeners() {
    const axisControls = document.querySelectorAll('.axis-control');
    axisControls.forEach(control => {
      const input = control.querySelector('input');
      const valueDisplay = control.querySelector('.axis-value');

      if (input && valueDisplay) {
        input.addEventListener('input', (e) => {
          const target = e.target as HTMLInputElement;
          valueDisplay.textContent = target.value;
          dispatchAxesChange();
        });
      }
    });
    dispatchAxesChange();
  }

  // Generate axes controls safely via DOM API
  function renderAxesControls(axes: typeof currentFontConfig.axes) {
    const detailsAxes = document.getElementById('details-axes');
    if (!detailsAxes) return;

    detailsAxes.innerHTML = ''; // Clear previous

    axes.forEach(axis => {
      const controlDiv = document.createElement('div');
      controlDiv.className = 'axis-control';
      controlDiv.setAttribute('data-axis', axis.tag);

      const headerDiv = document.createElement('div');
      headerDiv.className = 'flex justify-between items-center mb-1';

      const label = document.createElement('label');
      label.setAttribute('for', `axis-${axis.tag}`);
      label.className = 'text-[11px] font-bold text-slate-400 uppercase';
      label.textContent = `${axis.name} (${axis.tag})`;

      const valueSpan = document.createElement('span');
      valueSpan.className = 'text-[12px] font-medium text-gray-300 axis-value';
      valueSpan.textContent = String(axis.default);

      headerDiv.appendChild(label);
      headerDiv.appendChild(valueSpan);

      const input = document.createElement('input');
      input.id = `axis-${axis.tag}`;
      input.type = 'range';
      input.min = String(axis.min);
      input.max = String(axis.max);
      input.value = String(axis.default);
      input.step = '1';
      input.className = 'w-full accent-blue-500 cursor-pointer h-1.5 bg-gray-600 rounded-lg appearance-none';

      controlDiv.appendChild(headerDiv);
      controlDiv.appendChild(input);

      detailsAxes.appendChild(controlDiv);
    });

    setupSliderListeners();
  }


  // Handle font selection from LeftSidebar
  window.addEventListener('font-selected', ((event: CustomEvent) => {
    const fontId = event.detail.id;
    const fontConfig = fonts.find(f => f.id === fontId);

    if (fontConfig) {
      currentFontConfig = fontConfig;

      const detailsFontName = document.getElementById('details-font-name');
      const detailsFontType = document.getElementById('details-font-type');

      if (detailsFontName) detailsFontName.textContent = currentFontConfig.fontName;
      if (detailsFontType) detailsFontType.textContent = currentFontConfig.type;

      updateFeaturePreviews();
      renderAxesControls(currentFontConfig.axes);
    }
  }) as EventListener);

  // Initialize
  setupSliderListeners();
  updateFeaturePreviews();
  setupTypographyListeners();

  const featuresInputEl = document.getElementById('font-feature-settings-input');
  if (featuresInputEl) {
    featuresInputEl.addEventListener('input', dispatchAxesChange);
  }

  const featureToggles = document.querySelectorAll('.feature-toggle');
  featureToggles.forEach(toggle => {
     toggle.addEventListener('change', dispatchAxesChange);
  });

  // Helper to sync feature preview fonts
  function updateFeaturePreviews() {
     const previews = document.querySelectorAll('.feature-preview') as NodeListOf<HTMLElement>;
     previews.forEach(preview => {
        preview.style.fontFamily = currentFontConfig.fontFamily;
     });
  }

  // Copy CSS button functionality
  const copyBtn = document.getElementById('copy-css-btn');
  if (copyBtn) {
      copyBtn.addEventListener('click', () => {
          const codeToCopy = `${getFontFaceStr()}
.preview-text {
  font-family: ${currentFontConfig.fontFamily};
  font-size: ${typoState.fontSize};
  line-height: ${typoState.lineHeight};
  letter-spacing: ${typoState.letterSpacing};
  text-align: ${typoState.textAlign};
  color: ${typoState.color};
  font-variation-settings: ${getVariationSettingsStr()};
  font-feature-settings: ${getFontFeatureSettingsStr()};
}`;
          navigator.clipboard.writeText(codeToCopy).then(() => {
              const copyText = document.getElementById('copy-text');
              const copiedText = document.getElementById('copied-text');
              if (copyText && copiedText) {
                  copyText.style.transform = 'translateY(-100%)';
                  copiedText.style.transform = 'translateY(0%)';

                  setTimeout(() => {
                      copyText.style.transform = 'translateY(0%)';
                      copiedText.style.transform = 'translateY(100%)';
                  }, 2000);
              }
          });
      });
  }

  // Get Font button functionality
  const downloadBtn = document.getElementById('download-font-btn');
  if (downloadBtn) {
      downloadBtn.addEventListener('click', (e) => {
          e.preventDefault();

          let fileUrl = currentFontConfig.fileUrl;
          let fileName = currentFontConfig.fileName;

          // Visual Feedback for downloading
          const downloadText = document.getElementById('download-text');
          const downloadedText = document.getElementById('downloaded-text');

          if (downloadText && downloadedText) {
             downloadText.style.transform = 'translateY(-100%)';
             downloadedText.style.transform = 'translateY(0%)';

             setTimeout(() => {
                 downloadText.style.transform = 'translateY(0%)';
                 downloadedText.style.transform = 'translateY(100%)';
             }, 2000);
          }

          const link = document.createElement('a');
          link.href = fileUrl;
          link.download = fileName;
          document.body.appendChild(link);
          link.click();
          document.body.removeChild(link);
      });
  }
</script>
