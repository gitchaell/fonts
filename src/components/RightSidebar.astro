          let fileName = currentFontConfig.fileName;

          // Visual Feedback for downloading
          const downloadText = document.getElementById('download-text');
          const downloadedText = document.getElementById('downloaded-text');

          if (downloadText && downloadedText) {
             downloadText.style.transform = 'translateY(-100%)';
