---
import { Code } from 'astro:components';
import { defaultFont } from '../config/fonts';

interface Props {
  initialCSS: string;
}

const { initialCSS } = Astro.props;
---
<aside id="right-sidebar" class="w-full lg:w-[320px] lg:h-screen bg-[#1e1e1e] border-t lg:border-t-0 lg:border-l border-[#333] flex flex-col overflow-y-auto shrink-0 z-10 order-2 lg:order-3">
  <div class="p-6 pb-24 flex flex-col gap-8 h-full">

    <div>
      <h2 class="text-[11px] font-bold text-slate-400 uppercase tracking-wider mb-4">Font Details</h2>
      <div class="bg-[#2c2c2c] border border-[#333] rounded p-4 shadow-sm mb-6">
        <h3 class="text-xl font-bold text-white mb-1" id="details-font-name">{defaultFont.fontName}</h3>
        <p class="text-[13px] text-gray-400 mb-2" id="details-font-type">{defaultFont.type}</p>
        <p class="text-[11px] text-gray-500 mb-4" id="details-font-glyphs"></p>

        <div id="instances-container" class="mb-4 hidden">
          <label for="font-instances" class="text-[11px] font-bold text-slate-400 uppercase mb-1 block">Instances</label>
          <select id="font-instances" class="w-full bg-[#1e1e1e] border border-[#333] rounded px-2 py-1.5 text-[12px] text-white focus:outline-none focus:border-blue-500">
             <option value="">Default</option>
          </select>
        </div>

        <div class="space-y-4" id="details-axes">
           {defaultFont.axes.map(axis => (
             <div class="axis-control" data-axis={axis.tag}>
               <div class="flex justify-between items-center mb-1">
                 <label for={`axis-${axis.tag}`} class="text-[11px] font-bold text-slate-400 uppercase">{axis.name} ({axis.tag})</label>
                 <span class="text-[12px] font-medium text-gray-300 axis-value">{axis.default}</span>
               </div>
               <input id={`axis-${axis.tag}`} type="range" min={axis.min} max={axis.max} value={axis.default} step="1" class="w-full accent-blue-500 cursor-pointer">
             </div>
           ))}
        </div>
      </div>


      <!-- Typography Section -->
      <div class="bg-[#2c2c2c] border border-[#333] rounded p-4 shadow-sm mb-6">
        <h3 class="text-xs font-bold text-gray-400 uppercase tracking-wider mb-3">Typography</h3>

        <div class="space-y-4" id="typography-controls">
           <!-- Font Size -->
           <div class="typo-control">
             <div class="flex justify-between items-center mb-1">
               <label for="typo-size" class="text-[11px] font-bold text-slate-400 uppercase">Size (px)</label>
               <input id="typo-size-input" type="number" value="16" min="8" max="144" class="w-12 bg-[#1e1e1e] border border-[#333] rounded px-1 py-0.5 text-[11px] text-white text-right focus:outline-none focus:border-blue-500">
             </div>
             <input id="typo-size" type="range" min="8" max="144" value="16" step="1" class="w-full accent-blue-500 cursor-pointer">
           </div>

           <!-- Font Style -->
           <div class="typo-control">
             <label class="text-[11px] font-bold text-slate-400 uppercase mb-2 block">Font Style</label>
             <div class="flex bg-[#1e1e1e] rounded overflow-hidden border border-[#333]">
               <button class="fontstyle-btn flex-1 py-1 text-[11px] font-medium bg-[#3a3a3a] text-white border-r border-[#333] transition-colors" data-style="normal">Normal</button>
               <button class="fontstyle-btn flex-1 py-1 text-[11px] font-medium text-gray-400 hover:bg-[#2a2a2a] hover:text-white border-r border-[#333] transition-colors" data-style="italic">Italic</button>
               <button class="fontstyle-btn flex-1 py-1 text-[11px] font-medium text-gray-400 hover:bg-[#2a2a2a] hover:text-white transition-colors" data-style="oblique">Oblique</button>
             </div>
           </div>

           <!-- Line Height -->
           <div class="typo-control">
             <div class="flex justify-between items-center mb-1">
               <label for="typo-line-height" class="text-[11px] font-bold text-slate-400 uppercase">Line Height</label>
               <input id="typo-line-height-input" type="number" value="1.5" min="0.5" max="3" step="0.1" class="w-12 bg-[#1e1e1e] border border-[#333] rounded px-1 py-0.5 text-[11px] text-white text-right focus:outline-none focus:border-blue-500">
             </div>
             <input id="typo-line-height" type="range" min="0.5" max="3" value="1.5" step="0.1" class="w-full accent-blue-500 cursor-pointer">
           </div>

           <!-- Letter Spacing -->
           <div class="typo-control">
             <div class="flex justify-between items-center mb-1">
               <label for="typo-letter-spacing" class="text-[11px] font-bold text-slate-400 uppercase">Letter Spacing (em)</label>
               <input id="typo-letter-spacing-input" type="number" value="0" min="-0.1" max="0.5" step="0.01" class="w-12 bg-[#1e1e1e] border border-[#333] rounded px-1 py-0.5 text-[11px] text-white text-right focus:outline-none focus:border-blue-500">
             </div>
             <input id="typo-letter-spacing" type="range" min="-0.1" max="0.5" value="0" step="0.01" class="w-full accent-blue-500 cursor-pointer">
           </div>

           <!-- Word Spacing -->
           <div class="typo-control">
             <div class="flex justify-between items-center mb-1">
               <label for="typo-word-spacing" class="text-[11px] font-bold text-slate-400 uppercase">Word Spacing (em)</label>
               <input id="typo-word-spacing-input" type="number" value="0" min="-0.5" max="2" step="0.01" class="w-12 bg-[#1e1e1e] border border-[#333] rounded px-1 py-0.5 text-[11px] text-white text-right focus:outline-none focus:border-blue-500">
             </div>
             <input id="typo-word-spacing" type="range" min="-0.5" max="2" value="0" step="0.01" class="w-full accent-blue-500 cursor-pointer">
           </div>

           <!-- Text Indent -->
           <div class="typo-control">
             <div class="flex justify-between items-center mb-1">
               <label for="typo-text-indent" class="text-[11px] font-bold text-slate-400 uppercase">Text Indent (px)</label>
               <input id="typo-text-indent-input" type="number" value="0" min="0" max="100" step="1" class="w-12 bg-[#1e1e1e] border border-[#333] rounded px-1 py-0.5 text-[11px] text-white text-right focus:outline-none focus:border-blue-500">
             </div>
             <input id="typo-text-indent" type="range" min="0" max="100" value="0" step="1" class="w-full accent-blue-500 cursor-pointer">
           </div>

           <!-- Paragraph Spacing -->
           <div class="typo-control">
             <div class="flex justify-between items-center mb-1">
               <label for="typo-paragraph-spacing" class="text-[11px] font-bold text-slate-400 uppercase">Paragraph Spacing (em)</label>
               <input id="typo-paragraph-spacing-input" type="number" value="1" min="0" max="4" step="0.1" class="w-12 bg-[#1e1e1e] border border-[#333] rounded px-1 py-0.5 text-[11px] text-white text-right focus:outline-none focus:border-blue-500">
             </div>
             <input id="typo-paragraph-spacing" type="range" min="0" max="4" value="1" step="0.1" class="w-full accent-blue-500 cursor-pointer">
           </div>

           <!-- Alignment -->
           <div>
             <div class="text-[11px] font-bold text-slate-400 uppercase mb-2">Alignment</div>
             <div class="flex gap-1 bg-[#1e1e1e] p-1 rounded border border-[#333]" id="typo-align-group">
               <button data-align="left" class="flex-1 py-1.5 flex justify-center items-center rounded bg-[#3a3a3a] text-white transition-colors align-btn text-[10px]" aria-label="Align Left">Left</button>
               <button data-align="center" class="flex-1 py-1.5 flex justify-center items-center rounded text-gray-400 hover:text-white hover:bg-[#2a2a2a] transition-colors align-btn text-[10px]" aria-label="Align Center">Center</button>
               <button data-align="right" class="flex-1 py-1.5 flex justify-center items-center rounded text-gray-400 hover:text-white hover:bg-[#2a2a2a] transition-colors align-btn text-[10px]" aria-label="Align Right">Right</button>
               <button data-align="justify" class="flex-1 py-1.5 flex justify-center items-center rounded text-gray-400 hover:text-white hover:bg-[#2a2a2a] transition-colors align-btn text-[10px]" aria-label="Align Justify">Justify</button>
             </div>
           </div>

           <!-- Text Color -->
           <div>
             <div class="text-[11px] font-bold text-slate-400 uppercase mb-2">Color</div>
             <div class="flex items-center gap-2">
                 <input type="color" id="typo-color" value="#000000" class="w-8 h-8 rounded cursor-pointer bg-transparent border-0 p-0">
                 <input type="text" id="typo-color-text" value="#000000" class="flex-1 bg-[#1e1e1e] border border-[#333] rounded px-2 py-1 text-sm text-white focus:outline-none focus:border-blue-500 uppercase">
             </div>
           </div>

           <!-- Text Transform -->
           <div>
             <div class="text-[11px] font-bold text-slate-400 uppercase mb-2">Text Transform</div>
             <div class="flex gap-1 bg-[#1e1e1e] p-1 rounded border border-[#333]" id="typo-transform-group">
               <button data-transform="none" class="flex-1 py-1.5 flex justify-center items-center rounded bg-[#3a3a3a] text-white transition-colors transform-btn text-[10px] font-bold uppercase tracking-wider" aria-label="None">None</button>
               <button data-transform="uppercase" class="flex-1 py-1.5 flex justify-center items-center rounded text-gray-400 hover:text-white hover:bg-[#2a2a2a] transition-colors transform-btn text-[10px] font-bold uppercase tracking-wider" aria-label="Uppercase">UP</button>
               <button data-transform="lowercase" class="flex-1 py-1.5 flex justify-center items-center rounded text-gray-400 hover:text-white hover:bg-[#2a2a2a] transition-colors transform-btn text-[10px] font-bold lowercase tracking-wider" aria-label="Lowercase">low</button>
               <button data-transform="capitalize" class="flex-1 py-1.5 flex justify-center items-center rounded text-gray-400 hover:text-white hover:bg-[#2a2a2a] transition-colors transform-btn text-[10px] font-bold capitalize tracking-wider" aria-label="Capitalize">Cap</button>
             </div>
           </div>

           <!-- Text Decoration -->
           <div>
             <div class="text-[11px] font-bold text-slate-400 uppercase mb-2">Text Decoration</div>
             <div class="flex gap-1 bg-[#1e1e1e] p-1 rounded border border-[#333]" id="typo-decoration-group">
               <button data-decoration="none" class="flex-1 py-1.5 flex justify-center items-center rounded bg-[#3a3a3a] text-white transition-colors decoration-btn text-[10px] font-bold uppercase tracking-wider" aria-label="None">None</button>
               <button data-decoration="underline" class="flex-1 py-1.5 flex justify-center items-center rounded text-gray-400 hover:text-white hover:bg-[#2a2a2a] transition-colors decoration-btn text-[10px] font-bold underline tracking-wider" aria-label="Underline">U</button>
               <button data-decoration="line-through" class="flex-1 py-1.5 flex justify-center items-center rounded text-gray-400 hover:text-white hover:bg-[#2a2a2a] transition-colors decoration-btn text-[10px] font-bold line-through tracking-wider" aria-label="Line Through">S</button>
             </div>
           </div>

        </div>
      </div>

      <div class="bg-[#2c2c2c] border border-[#333] rounded p-4 shadow-sm mb-6">
        <h3 class="text-xs font-bold text-gray-400 uppercase tracking-wider mb-3">Font Features</h3>

        <div class="space-y-4" id="font-features-container">
           <div id="dynamic-font-features" class="space-y-4"></div>
        </div>
      </div>
    </div>

    <!-- Output Section -->
    <div class="mt-auto">
      <div class="flex justify-between items-center mb-4">
        <h2 class="text-[11px] font-bold text-slate-400 uppercase tracking-wider">CSS Output</h2>
        <button id="copy-css-btn" class="text-[11px] font-medium text-blue-400 hover:text-blue-300 transition-colors flex items-center justify-end overflow-hidden relative h-5 w-20" aria-label="Copy CSS">
           <span id="copy-text" class="absolute inset-0 flex items-center justify-end gap-1.5 transition-transform duration-300">
              <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
              Copy
           </span>
           <span id="copied-text" class="absolute inset-0 flex items-center justify-end gap-1.5 text-green-400 transition-transform duration-300 translate-y-full">
              <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"></polyline></svg>
              Copied!
           </span>
        </button>
      </div>

      <div id="css-output-container" class="bg-[#1a1b26] rounded border border-[#333] p-4 text-[12px] font-mono overflow-x-auto shadow-inner mb-6">
        <Code code={initialCSS} lang="css" theme="github-dark" />
      </div>

      <button id="download-font-btn" class="w-full bg-blue-600 hover:bg-blue-700 text-white font-medium py-2.5 px-4 rounded transition-colors flex items-center justify-center gap-2 relative overflow-hidden" aria-label="Download Font">
        <span id="download-text" class="flex items-center gap-2 transition-transform duration-300">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
          Get Font
        </span>
        <span id="downloaded-text" class="absolute inset-0 flex items-center justify-center text-white transition-transform duration-300 translate-y-full">
          <svg class="w-4 h-4 mr-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"></polyline></svg>
          Downloading...
        </span>
      </button>
    </div>
  </div>
</aside>

<script>
  import * as fontkit from 'fontkit';
  import { Buffer } from 'buffer';
  window.Buffer = Buffer;

  import { fonts, defaultFont } from '../config/fonts';

  let currentFontConfig = defaultFont;

  function extractNamedVariations(font: any) {
    let variations = {};
    try {
      if (font.namedVariations) {
        variations = font.namedVariations;
      }
    } catch (e) {
      // Fallback for fonts that throw TypeError in fontkit getter (e.g. GeistVF)
      const nameIdMap: Record<number, string> = {
        1: 'fontFamily',
        2: 'fontSubfamily',
        3: 'uniqueSubfamily',
        4: 'fullName',
        5: 'version',
        6: 'postscriptName',
        16: 'preferredFamily',
        17: 'preferredSubfamily',
      };

      let res: Record<string, Record<string, number>> = {};
      if (font.fvar && font.fvar.instance) {
          for (let instance of font.fvar.instance){
              let settings: Record<string, number> = {};
              if (font.fvar.axis) {
                  for(let i = 0; i < font.fvar.axis.length; i++){
                      let axis = font.fvar.axis[i];
                      if (instance.coord && instance.coord[i] !== undefined) {
                          settings[axis.axisTag.trim()] = instance.coord[i];
                      }
                  }
              }

              let name = null;
              if (instance.name && instance.name.en) {
                 name = instance.name.en;
              } else if (instance.nameID && font.name && font.name.records) {
                 let recordName = nameIdMap[instance.nameID] || instance.nameID;
                 const record = font.name.records[recordName];
                 if (record && record.en) {
                     name = record.en;
                 }
              }
              if (!name) name = `Instance ${instance.nameID}`;

              res[name] = settings;
          }
      }
      variations = res;
    }
    return variations;
  }


  function extractAvailableFeatures(font: any): string[] {
    const allFeatures = new Set<string>(font.availableFeatures || []);

    const extractTags = (records: any) => {
        if (!records) return;
        if (Array.isArray(records)) {
            records.forEach(r => {
                if (typeof r === 'string') allFeatures.add(r);
                else if (r && r.tag) allFeatures.add(r.tag);
            });
        }
    };

    if (font.GSUB && font.GSUB.featureList) extractTags(font.GSUB.featureList);
    if (font.GPOS && font.GPOS.featureList) extractTags(font.GPOS.featureList);
    if (font.GSUB && font.GSUB.featureRecords) extractTags(font.GSUB.featureRecords);
    if (font.GPOS && font.GPOS.featureRecords) extractTags(font.GPOS.featureRecords);

    // Hardcode features for Inter as fontkit fails to parse WOFF2 correctly
    if (currentFontConfig && currentFontConfig.fileName && currentFontConfig.fileName.toLowerCase().includes('inter')) {
        const interFeatures = ['calt','case','ccmp','cv01','cv02','cv03','cv04','cv05','cv06','cv07','cv08','cv09','cv10','cv11','dnom','frac','kern','liga','locl','mark','mkmk','numr','ordn','pnum','salt','sinf','ss01','ss02','ss03','ss04','ss05','ss06','ss07','ss08','subs','sups','tnum','zero'];
        interFeatures.forEach(f => allFeatures.add(f));
    }

    return Array.from(allFeatures);
  }

  function getVariationSettingsStr() {
    const activeAxes = document.querySelectorAll('.axis-control');
    if(activeAxes.length === 0) return 'normal';

    let settings: string[] = [];
    activeAxes.forEach(control => {
      const axis = control.getAttribute('data-axis');
      const input = control.querySelector('input');
      if (axis && input) {
        settings.push(`'${axis}' ${input.value}`);
      }
    });
    return settings.join(', ');
  }

  function getFontFaceStr() {
    return currentFontConfig.fontFace;
  }


  let typoState = {
    fontSize: '16px',
    lineHeight: '1.5',
    letterSpacing: '0em',
    wordSpacing: '0em',
    textAlign: 'left',
    color: '#000000',
    textTransform: 'none',
    textDecoration: 'none',
    fontStyle: 'normal',
    textIndent: '0px',
    paragraphSpacing: '1em'
  };

  const otFeatures = [
    { category: 'Ligatures & Contextual', features: [ { tag: 'liga', name: 'Standard Ligatures', preview: 'fi' }, { tag: 'dlig', name: 'Discretionary Ligatures', preview: 'ct' }, { tag: 'calt', name: 'Contextual Alternates', preview: '->' }, { tag: 'hlig', name: 'Historical Ligatures', preview: 'st' }, { tag: 'rclt', name: 'Required Contextual Alternates', preview: '->' } ] },
    { category: 'Capitals', features: [ { tag: 'smcp', name: 'Small Capitals', preview: 'Aa' }, { tag: 'c2sc', name: 'Capitals to Small Caps', preview: 'AA' }, { tag: 'case', name: 'Case-Sensitive Forms', preview: '(H)' }, { tag: 'titl', name: 'Titling Alternates', preview: 'H' }, { tag: 'pcap', name: 'Petite Capitals', preview: 'Aa' }, { tag: 'c2pc', name: 'Capitals to Petite Caps', preview: 'AA' }, { tag: 'unic', name: 'Unicase', preview: 'aA' } ] },
    { category: 'Numerics', features: [ { tag: 'lnum', name: 'Lining Figures', preview: '12' }, { tag: 'onum', name: 'Oldstyle Figures', preview: '12' }, { tag: 'pnum', name: 'Proportional Figures', preview: '12' }, { tag: 'tnum', name: 'Tabular Figures', preview: '12' }, { tag: 'frac', name: 'Fractions', preview: '1/2' }, { tag: 'afrc', name: 'Alternative Fractions', preview: '1/2' }, { tag: 'ordn', name: 'Ordinals', preview: '1st' }, { tag: 'zero', name: 'Slashed Zero', preview: '0' } ] },
    { category: 'Position', features: [ { tag: 'sups', name: 'Superscript', preview: 'x²' }, { tag: 'subs', name: 'Subscript', preview: 'x₂' }, { tag: 'sinf', name: 'Scientific Inferiors', preview: 'x₂' }, { tag: 'numr', name: 'Numerator', preview: '1/' }, { tag: 'dnom', name: 'Denominator', preview: '/2' } ] },
    { category: 'Stylistic', features: [ { tag: 'swsh', name: 'Swash', preview: 'Q' }, { tag: 'cswh', name: 'Contextual Swash', preview: 'Q' }, { tag: 'salt', name: 'Stylistic Alternates', preview: 'a' }, { tag: 'ss01', name: 'Stylistic Set 1', preview: '1' }, { tag: 'ss02', name: 'Stylistic Set 2', preview: '2' }, { tag: 'ss03', name: 'Stylistic Set 3', preview: '3' }, { tag: 'ss04', name: 'Stylistic Set 4', preview: '4' }, { tag: 'ss05', name: 'Stylistic Set 5', preview: '5' }, { tag: 'ss06', name: 'Stylistic Set 6', preview: '6' }, { tag: 'ss07', name: 'Stylistic Set 7', preview: '7' }, { tag: 'ss08', name: 'Stylistic Set 8', preview: '8' }, { tag: 'ss09', name: 'Stylistic Set 9', preview: '9' }, { tag: 'ss10', name: 'Stylistic Set 10', preview: '10' }, { tag: 'ss11', name: 'Stylistic Set 11', preview: '11' }, { tag: 'ss12', name: 'Stylistic Set 12', preview: '12' }, { tag: 'ss13', name: 'Stylistic Set 13', preview: '13' }, { tag: 'ss14', name: 'Stylistic Set 14', preview: '14' }, { tag: 'ss15', name: 'Stylistic Set 15', preview: '15' }, { tag: 'ss16', name: 'Stylistic Set 16', preview: '16' }, { tag: 'ss17', name: 'Stylistic Set 17', preview: '17' }, { tag: 'ss18', name: 'Stylistic Set 18', preview: '18' }, { tag: 'ss19', name: 'Stylistic Set 19', preview: '19' }, { tag: 'ss20', name: 'Stylistic Set 20', preview: '20' } ] },
    { category: 'Character Variants', features: [ { tag: 'cv01', name: 'Character Variant 1', preview: 'A' }, { tag: 'cv02', name: 'Character Variant 2', preview: 'B' }, { tag: 'cv03', name: 'Character Variant 3', preview: 'C' }, { tag: 'cv04', name: 'Character Variant 4', preview: 'D' }, { tag: 'cv05', name: 'Character Variant 5', preview: 'E' } ] }
  ];


  const requiredFeaturesList = [
    { tag: 'ccmp', name: 'Glyph Composition/Decomposition' },
    { tag: 'locl', name: 'Localized Forms' },
    { tag: 'rvrn', name: 'Required Variation Alternates' },
    { tag: 'mark', name: 'Mark Positioning' },
    { tag: 'mkmk', name: 'Mark to Mark Positioning' },
    { tag: 'kern', name: 'Kerning' }
  ];

  function renderDynamicFontFeatures(availableFeatures: string[] = []) {
    const container = document.getElementById('dynamic-font-features');
    if (!container) return;

    container.innerHTML = '';

    const activeRequired = requiredFeaturesList.filter(f => availableFeatures.includes(f.tag));

    let htmlStr = '';

    if (activeRequired.length > 0) {
      htmlStr += `
      <div class="mb-4">
        <h4 class="text-[11px] font-bold text-gray-500 uppercase mb-2">Required Features</h4>
        <p class="text-[10px] text-gray-400 mb-2">These are always turned on by default.</p>
        <div class="space-y-1">
          ${activeRequired.map(f => `
            <div class="text-[12px] text-gray-300 flex items-center justify-between bg-[#1e1e1e] p-2 rounded border border-[#333]">
              <span>${f.name}</span>
              <span class="text-[10px] font-mono text-gray-500 bg-[#2c2c2c] px-1 rounded">${f.tag}</span>
            </div>
          `).join('')}
        </div>
      </div>
      `;
    }

    const filteredGroups = otFeatures.map(group => {
      // Filter out required features from optional groups to avoid duplication
      const requiredTags = requiredFeaturesList.map(r => r.tag);
      const activeFeatures = group.features.filter(f => availableFeatures.includes(f.tag) && !requiredTags.includes(f.tag));
      return { ...group, features: activeFeatures };
    }).filter(group => group.features.length > 0);

    if (filteredGroups.length === 0) {
       if (activeRequired.length === 0) {
           htmlStr += '<p class="text-[12px] text-gray-500 italic">No advanced OpenType features found in this font.</p>';
       } else {
