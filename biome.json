{
	"$schema": "https://biomejs.dev/schemas/2.5.3/schema.json",
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"indentWidth": 2
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "single"
		}
	},
	"overrides": [
		{
			"includes": ["*.astro", "**/*.astro"],
			"linter": {
				"enabled": true
			},
			"formatter": {
				"enabled": true
			}
		}
	]
}
